<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <!-- Noms de tests xUnit avec underscores (convention du repo, cf. tests/Modules/Job). -->
    <NoWarn>$(NoWarn);CA1707</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" PrivateAssets="all" />
    <PackageReference Include="FluentAssertions" />
    <!-- Référence directe : garantit la copie du natif SQLite.Interop.dll (x86/x64) dans la sortie
         de test pour les tests réels de la file locale (System.Data.SQLite est tiré transitivement
         par Core, mais on force ici la propagation des cibles de copie du natif). -->
    <PackageReference Include="System.Data.SQLite.Core" />
  </ItemGroup>

  <!-- Référence les trois assemblies « bibliothèque » de l'agent pour vérifier leurs frontières. -->
  <ItemGroup>
    <ProjectReference Include="..\..\src\Liakont.Agent.Core\Liakont.Agent.Core.csproj" />
    <ProjectReference Include="..\..\src\Liakont.Agent.Adapters.EncheresV6\Liakont.Agent.Adapters.EncheresV6.csproj" />
    <ProjectReference Include="..\..\..\src\Contracts\Liakont.Agent.Contracts\Liakont.Agent.Contracts.csproj" />
  </ItemGroup>

  <!-- Client HTTP (tests du HttpPlatformClient contre un serveur HttpListener mocké, AGT02). -->
  <ItemGroup>
    <Reference Include="System.Net.Http" />
    <!-- Fabrication d'un paquet ZIP de test pour l'auto-update (AGT04). -->
    <Reference Include="System.IO.Compression" />
  </ItemGroup>

  <!-- Tests de contrat CROSS-RUNTIME (PIV02) partagés avec la solution plateforme (.NET 10) : le MÊME
       code golden + lecteur, lié des deux côtés, prouve la sérialisation/empreinte identiques (F12 §3.4). -->
  <ItemGroup>
    <Compile Include="..\..\..\tests\_shared\contract-v1\PivotCanonicalReader.cs" Link="ContractV1\PivotCanonicalReader.cs" />
    <Compile Include="..\..\..\tests\_shared\contract-v1\PivotContractGoldenTests.cs" Link="ContractV1\PivotContractGoldenTests.cs" />
    <Compile Include="..\..\..\tests\_shared\contract-v1\ContractFixtures.cs" Link="ContractV1\ContractFixtures.cs" />
    <Compile Include="..\..\..\tests\_shared\contract-v1\ContractFixtureTests.cs" Link="ContractV1\ContractFixtureTests.cs" />
  </ItemGroup>

  <!-- Golden files du contrat v1 (PIV03) : copiés en sortie pour être lus côté agent (net48) avec
       les MÊMES fichiers et les MÊMES empreintes que la plateforme — preuve cross-runtime. -->
  <ItemGroup>
    <None Include="..\..\..\tests\fixtures\contrat-v1\*.json" Link="fixtures\contrat-v1\%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
