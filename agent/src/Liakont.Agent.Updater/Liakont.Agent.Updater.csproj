<Project Sdk="Microsoft.NET.Sdk">

  <!-- Updater AUTONOME de l'agent (AGT04, ADR-0013) : un petit exe séparé, SANS dépendance à
       Liakont.Agent.Core (ni SQLite, ni contrat). Il survit à l'arrêt du service qu'il pilote et ne
       tourne jamais depuis le dossier qu'il remplace. Contrat agent ↔ updater = arguments de ligne
       de commande + un fichier statut JSON (couplage faible). -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>Liakont.Agent.Updater</RootNamespace>
    <AssemblyName>Liakont.Agent.Updater</AssemblyName>
  </PropertyGroup>

  <!-- Pilotage du service Windows (arrêt/démarrage/attente d'état) : assembly du framework net48. -->
  <ItemGroup>
    <Reference Include="System.ServiceProcess" />
  </ItemGroup>

</Project>
