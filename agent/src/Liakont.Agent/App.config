<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <runtime>
    <!-- Durcissement TLS net48 (RDF01, ADR-0001) : force le framework à utiliser SChannel strong
         crypto (TLS 1.2+) même sur un hôte dont la clé de registre SchUseStrongCrypto n'est PAS posée.
         Défense en profondeur du forçage code (AgentTls.ForceStrongTls au démarrage du service) ;
         aucun secret ni donnée client (CLAUDE.md n°7/n°10). -->
    <AppContextSwitchOverrides value="Switch.System.Net.DontEnableSchUseStrongCrypto=false" />
  </runtime>
</configuration>
