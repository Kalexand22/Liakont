root = true

[*]
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{csproj,props,targets,xml,xaml}]
indent_size = 2

[*.{json,yaml,yml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.ps1]
indent_size = 4

[*.cs]
# Namespaces : file-scoped autorisés par C# 10+ ; net48 + LangVersion latest les supporte
csharp_style_namespace_declarations = file_scoped:suggestion

# Using directives hors namespace (convention .NET Framework classique)
csharp_using_directive_placement = outside_namespace:error

# var uniquement quand le type est évident
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Nommage : PascalCase pour les types et membres publics
dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case_style
dotnet_naming_rule.types_should_be_pascal_case.severity = error

dotnet_naming_symbols.types.applicable_kinds = class, struct, interface, enum, delegate, event, method, property
dotnet_naming_symbols.types.applicable_accessibilities = *

dotnet_naming_style.pascal_case_style.capitalization = pascal_case

# Nommage : camelCase pour paramètres et variables locales
dotnet_naming_rule.locals_should_be_camel_case.symbols = locals
dotnet_naming_rule.locals_should_be_camel_case.style = camel_case_style
dotnet_naming_rule.locals_should_be_camel_case.severity = error

dotnet_naming_symbols.locals.applicable_kinds = parameter, local
dotnet_naming_style.camel_case_style.capitalization = camel_case

# Interdire float/double pour les montants — pas applicable via editorconfig,
# règle vérifiée par codex-review (voir CLAUDE.md, règle « montants en decimal »)
