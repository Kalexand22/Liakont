@namespace Stratum.Common.UI.Components
@typeparam TItem where TItem : notnull

@* StratumColumnChooser<TItem> — column visibility and order chooser panel.
 *
 * Opens in a StratumDialog. Shows all available columns from the registry,
 * grouped by Category. User can toggle visibility (checkboxes), reorder
 * visible columns via drag & drop (GUX10 — replaced the previous ↑↓ buttons),
 * and reset to defaults. Keyboard users can still reorder with Arrow Up / Arrow Down
 * while the list item has focus.
 *
 * Usage:
 *   <StratumColumnChooser TItem="PartyDto"
 *                         @bind-Visible="_showChooser"
 *                         Registry="@_registry"
 *                         VisibleColumnKeys="@_visibleKeys"
 *                         OnApply="HandleColumnsApplied" />
 *
 * Ref: docs/architecture/ui-architecture-plan.md §4.
 *@

<StratumDialog Title="@Title"
               Visible="@Visible"
               VisibleChanged="HandleVisibleChanged"
               Width="480px"
               TestId="@(TestId ?? "stratum-column-chooser")">
    <ChildContent>
        <div class="stratum-column-chooser" role="region" aria-label="@Title">
            @if (_columnsByCategory is not null)
            {
                <div class="stratum-column-chooser__categories">
                    @foreach (var category in _columnsByCategory)
                    {
                        <fieldset class="stratum-column-chooser__group">
                            <legend class="stratum-column-chooser__group-title">@category.Key</legend>
                            @foreach (var col in category.Value)
                            {
                                var isChecked = _workingKeys.Contains(col.Key);
                                <div class="stratum-column-chooser__item">
                                    <label class="stratum-column-chooser__label">
                                        <input type="checkbox"
                                               checked="@isChecked"
                                               @onchange="@(e => HandleToggle(col.Key, (bool)(e.Value ?? false)))"
                                               class="stratum-column-chooser__checkbox"
                                               aria-label="@($"{col.Title} — {(isChecked ? "visible" : "masquée")}")" />
                                        <span class="stratum-column-chooser__column-name">@col.Title</span>
                                        @if (col.IsRelatedEntity)
                                        {
                                            <span class="stratum-column-chooser__display-format"
                                                  title="Formaté via DisplayTemplate">
                                                (format)
                                            </span>
                                        }
                                    </label>
                                </div>
                            }
                        </fieldset>
                    }
                </div>

                @if (_workingKeys.Count > 0)
                {
                    <div class="stratum-column-chooser__order-section">
                        <h3 class="stratum-column-chooser__order-title">Ordre des colonnes</h3>
                        <p class="stratum-column-chooser__order-hint">
                            Glissez-déposez pour réorganiser. Au clavier : <kbd>↑</kbd> / <kbd>↓</kbd> pour déplacer l'élément ciblé.
                        </p>
                        <ol class="stratum-column-chooser__order-list"
                            role="list"
                            aria-label="Ordre des colonnes visibles"
                            data-testid="@($"{(TestId ?? "stratum-column-chooser")}-order-list")">
                            @for (var i = 0; i < _workingKeys.Count; i++)
                            {
                                var index = i;
                                var key = _workingKeys[i];
                                var col = Registry?.GetColumn(key);
                                var title = col?.Title ?? key;
                                var isDragOver = _dragOverIndex == index;
                                var isDragging = _draggingIndex == index;
                                var itemClass = "stratum-column-chooser__order-item"
                                    + (isDragging ? " stratum-column-chooser__order-item--dragging" : string.Empty)
                                    + (isDragOver ? " stratum-column-chooser__order-item--drag-over" : string.Empty);
                                <li @key="key"
                                    class="@itemClass"
                                    draggable="true"
                                    tabindex="0"
                                    role="listitem"
                                    aria-label="@($"{title} — position {index + 1} sur {_workingKeys.Count}")"
                                    data-column-key="@key"
                                    data-testid="@($"column-order-item-{key}")"
                                    @ondragstart="@(() => HandleDragStart(index))"
                                    @ondragstart:stopPropagation="true"
                                    @ondragenter="@(() => HandleDragEnter(index))"
                                    @ondragenter:preventDefault="true"
                                    @ondragover:preventDefault="true"
                                    @ondragleave="@(() => HandleDragLeave(index))"
                                    @ondrop="@(() => HandleDrop(index))"
                                    @ondrop:preventDefault="true"
                                    @ondragend="@HandleDragEnd"
                                    @onkeydown="@(e => HandleOrderKeyDown(e, index))">
                                    <span class="stratum-column-chooser__drag-handle material-symbols-outlined"
                                          aria-hidden="true">drag_indicator</span>
                                    <span class="stratum-column-chooser__order-label">@title</span>
                                </li>
                            }
                        </ol>
                    </div>
                }
            }
        </div>
    </ChildContent>
    <Actions>
        <button type="button"
                class="btn btn-sm btn-outline-secondary"
                @onclick="HandleReset"
                aria-label="Réinitialiser les colonnes par défaut">
            Réinitialiser
        </button>
        <button type="button"
                class="btn btn-sm btn-outline-secondary"
                @onclick="HandleCancel">
            Annuler
        </button>
        <button type="button"
                class="btn btn-sm btn-primary"
                @onclick="HandleApply">
            Appliquer
        </button>
    </Actions>
</StratumDialog>

@code {
    // ── Parameters ────────────────────────────────────────────────

    /// <summary>Optional test identifier.</summary>
    [Parameter]
    public string? TestId { get; set; }

    /// <summary>Dialog title. Default: "Colonnes".</summary>
    [Parameter]
    public string Title { get; set; } = "Colonnes";

    /// <summary>Whether the chooser dialog is visible (two-way binding).</summary>
    [Parameter]
    public bool Visible { get; set; }

    /// <summary>Raised when visibility changes.</summary>
    [Parameter]
    public EventCallback<bool> VisibleChanged { get; set; }

    /// <summary>Column registry providing available columns and categories.</summary>
    [Parameter]
    public IColumnRegistry<TItem>? Registry { get; set; }

    /// <summary>
    /// Current visible column keys in display order.
    /// When null, the registry's default visible columns are used.
    /// </summary>
    [Parameter]
    public IReadOnlyList<string>? VisibleColumnKeys { get; set; }

    /// <summary>
    /// Raised when the user clicks Apply. Provides the new ordered list of visible column keys.
    /// </summary>
    [Parameter]
    public EventCallback<IReadOnlyList<string>> OnApply { get; set; }

    /// <summary>Raised when the user clicks Cancel or closes the dialog.</summary>
    [Parameter]
    public EventCallback OnCancel { get; set; }

    // ── Internal state ────────────────────────────────────────────

    private IReadOnlyDictionary<string, IReadOnlyList<ColumnDefinition>>? _columnsByCategory;
    private List<string> _workingKeys = [];
    private bool _initialized;

    // GUX10 — drag & drop reorder state. _draggingIndex is the index the user
    // picked up; _dragOverIndex is the current hover target used for visual
    // feedback. Both are reset on drop/dragend.
    private int? _draggingIndex;
    private int? _dragOverIndex;

    // ── Lifecycle ─────────────────────────────────────────────────

    protected override void OnParametersSet()
    {
        if (Registry is null) return;

        _columnsByCategory = Registry.GetColumnsByCategory();

        if (Visible && !_initialized)
        {
            InitializeWorkingKeys();
            _initialized = true;
        }
        else if (!Visible)
        {
            _initialized = false;
        }
    }

    private void InitializeWorkingKeys()
    {
        if (Registry is null) return;

        if (VisibleColumnKeys is not null && VisibleColumnKeys.Count > 0)
        {
            _workingKeys = new List<string>(VisibleColumnKeys);
        }
        else
        {
            _workingKeys = Registry.GetDefaultVisibleColumns()
                .Select(c => c.Key)
                .ToList();
        }
    }

    // ── Toggle visibility ────────────────────────────────────────

    private void HandleToggle(string key, bool isChecked)
    {
        if (isChecked && !_workingKeys.Contains(key))
        {
            _workingKeys.Add(key);
        }
        else if (!isChecked)
        {
            _workingKeys.Remove(key);
        }
    }

    // ── Reorder (GUX10 — drag & drop + keyboard arrow fallback) ─────

    /// <summary>
    /// Moves the entry at <paramref name="fromIndex"/> to <paramref name="toIndex"/>
    /// within <see cref="_workingKeys"/>. No-op when indices are out of range or equal.
    /// Exposed for direct manipulation by drag & drop handlers and keyboard shortcuts.
    /// </summary>
    internal void MoveItem(int fromIndex, int toIndex)
    {
        if (fromIndex < 0 || fromIndex >= _workingKeys.Count) return;
        if (toIndex < 0 || toIndex >= _workingKeys.Count) return;
        if (fromIndex == toIndex) return;

        var key = _workingKeys[fromIndex];
        _workingKeys.RemoveAt(fromIndex);
        _workingKeys.Insert(toIndex, key);
    }

    // ── Drag & drop handlers ────────────────────────────────────

    private void HandleDragStart(int index)
    {
        _draggingIndex = index;
        _dragOverIndex = index;
    }

    private void HandleDragEnter(int index)
    {
        if (_draggingIndex is null) return;
        _dragOverIndex = index;
    }

    private void HandleDragLeave(int index)
    {
        // Only clear the hover state if we're leaving the currently tracked
        // target. Leaving a non-target row (e.g. during a fast sweep) must not
        // wipe the drop indicator that was just set by a sibling dragenter.
        if (_dragOverIndex == index)
        {
            _dragOverIndex = null;
        }
    }

    private void HandleDrop(int index)
    {
        if (_draggingIndex is int from)
        {
            MoveItem(from, index);
        }

        _draggingIndex = null;
        _dragOverIndex = null;
    }

    private void HandleDragEnd()
    {
        _draggingIndex = null;
        _dragOverIndex = null;
    }

    // Keyboard a11y: ArrowUp / ArrowDown move the focused item up or down by
    // one slot. Matches the GUX10 acceptance that keyboard users must still
    // be able to reorder after the ↑↓ buttons were removed.
    private void HandleOrderKeyDown(KeyboardEventArgs e, int index)
    {
        if (e.Key == "ArrowUp" && index > 0)
        {
            MoveItem(index, index - 1);
        }
        else if (e.Key == "ArrowDown" && index < _workingKeys.Count - 1)
        {
            MoveItem(index, index + 1);
        }
    }

    // ── Actions ──────────────────────────────────────────────────

    private void HandleReset()
    {
        if (Registry is null) return;

        _workingKeys = Registry.GetDefaultVisibleColumns()
            .Select(c => c.Key)
            .ToList();
    }

    private async Task HandleApply()
    {
        await OnApply.InvokeAsync(_workingKeys.AsReadOnly());
        await VisibleChanged.InvokeAsync(false);
    }

    private async Task HandleCancel()
    {
        await VisibleChanged.InvokeAsync(false);
        await OnCancel.InvokeAsync();
    }

    private async Task HandleVisibleChanged(bool value)
    {
        await VisibleChanged.InvokeAsync(value);
    }
}
