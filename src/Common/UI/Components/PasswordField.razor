@namespace Stratum.Common.UI.Components

<div class="password-field @CssClass @(Disabled ? "password-field--disabled" : string.Empty)"
     data-testid="@TestId">
    <div class="password-field__wrap">
        <input type="@(_visible ? "text" : "password")"
               id="@_inputId"
               class="password-field__input"
               value="@Value"
               placeholder="@Placeholder"
               autocomplete="@AutoComplete"
               disabled="@Disabled"
               aria-label="@(_context == null ? (AriaLabel ?? "Password") : null)"
               aria-invalid="@(_context?.HasError == true ? "true" : null)"
               aria-describedby="@_context?.DescribedBy"
               @oninput="OnInput" />

        @if (ShowToggle)
        {
            <button type="button"
                    class="password-field__toggle"
                    aria-label="@(_visible ? "Masquer le mot de passe" : "Afficher le mot de passe")"
                    disabled="@Disabled"
                    @onclick="ToggleVisibility">
                @if (_visible)
                {
                    <span aria-hidden="true">🙈</span>
                }
                else
                {
                    <span aria-hidden="true">👁</span>
                }
            </button>
        }
    </div>

    @if (ShowStrength && !string.IsNullOrEmpty(Value))
    {
        var rawScore = ComputeRawScore(Value);
        var level = MapLevel(rawScore);
        var levelName = level switch { 0 => "Très faible", 1 => "Faible", 2 => "Moyen", _ => "Fort" };
        var levelMod = level switch { 0 => "very-weak", 1 => "weak", 2 => "medium", _ => "strong" };

        <div class="password-field__strength">
            <div class="password-field__strength-bar"
                 role="meter"
                 aria-label="Force du mot de passe"
                 aria-valuenow="@rawScore"
                 aria-valuemin="0"
                 aria-valuemax="4">
                <div class="password-field__strength-fill password-field__strength-fill--@levelMod"
                     style="width: @(rawScore * 25)%"></div>
            </div>
            <span class="password-field__strength-label password-field__strength-label--@levelMod">@levelName</span>
        </div>
    }
</div>

@code {
    [CascadingParameter]
    private FormFieldContext? _context { get; set; }

    /// <summary>Accessible label for the input when used without FormField.</summary>
    [Parameter] public string? AriaLabel { get; set; }

    /// <summary>Password value (two-way).</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Raised when the value changes.</summary>
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>Placeholder text.</summary>
    [Parameter] public string? Placeholder { get; set; }

    /// <summary>Show visibility toggle button. Default: true.</summary>
    [Parameter] public bool ShowToggle { get; set; } = true;

    /// <summary>Show strength indicator bar below the field. Default: false.</summary>
    [Parameter] public bool ShowStrength { get; set; }

    /// <summary>HTML autocomplete attribute value. Default: "current-password".</summary>
    [Parameter] public string AutoComplete { get; set; } = "current-password";

    /// <summary>Disabled — no interaction.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Additional CSS classes on root element.</summary>
    [Parameter] public string? CssClass { get; set; }

    /// <summary>Test identifier for E2E tests.</summary>
    [Parameter] public string? TestId { get; set; }

    // ── State ─────────────────────────────────────────────────────

    private bool _visible;
    private readonly string _inputId = $"pwd-{Guid.NewGuid():N}";

    // ── Events ────────────────────────────────────────────────────

    private async Task OnInput(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        await ValueChanged.InvokeAsync(string.IsNullOrEmpty(val) ? null : val);
    }

    private void ToggleVisibility() => _visible = !_visible;

    // ── Pure helpers (internal for testability) ───────────────────

    internal static int ComputeRawScore(string? password)
    {
        if (string.IsNullOrEmpty(password)) return 0;
        int score = 0;
        if (password.Length >= 8)                        score++;
        if (password.Any(char.IsUpper))                  score++;
        if (password.Any(char.IsDigit))                  score++;
        if (password.Any(c => !char.IsLetterOrDigit(c))) score++;
        return score;
    }

    internal static int MapLevel(int rawScore) =>
        rawScore switch { 0 => 0, 1 => 1, 2 or 3 => 2, _ => 3 };

    internal static int ComputeStrength(string? password) => MapLevel(ComputeRawScore(password));
}
