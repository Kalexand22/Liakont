@namespace Stratum.Common.UI.Components

<div class="url-field @CssClass @(Disabled ? "url-field--disabled" : string.Empty)"
     data-testid="@TestId">
    <div class="url-field__wrap">
        <input type="url"
               id="@_inputId"
               class="url-field__input @(_invalid ? "url-field__input--error" : string.Empty)"
               value="@Value"
               placeholder="@(Placeholder ?? "https://")"
               autocomplete="url"
               inputmode="url"
               aria-invalid="@(_invalid ? "true" : null)"
               aria-describedby="@(_invalid ? _errorId : null)"
               disabled="@Disabled"
               readonly="@ReadOnly"
               aria-readonly="@(ReadOnly ? "true" : null)"
               @oninput="OnInput"
               @onblur="OnBlur" />

        @if (ShowLinkIcon && IsValidUrl(Value))
        {
            <a href="@Value"
               target="_blank"
               rel="noopener noreferrer"
               class="url-field__link"
               aria-label="Ouvrir @Value dans un nouvel onglet"
               title="Ouvrir dans un nouvel onglet">🔗</a>
        }
    </div>

    @if (_invalid)
    {
        <span id="@_errorId" class="url-field__error" role="alert">URL invalide (doit commencer par https:// ou http://).</span>
    }
</div>

@code {
    /// <summary>URL value (two-way).</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Raised when the value changes.</summary>
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>Placeholder. Default: "https://".</summary>
    [Parameter] public string? Placeholder { get; set; }

    /// <summary>Show an external link icon when a valid URL is present. Default: true.</summary>
    [Parameter] public bool ShowLinkIcon { get; set; } = true;

    /// <summary>Disabled — no interaction.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Read-only — focusable but not editable.</summary>
    [Parameter] public bool ReadOnly { get; set; }

    /// <summary>Additional CSS classes on root element.</summary>
    [Parameter] public string? CssClass { get; set; }

    /// <summary>Test identifier for E2E tests.</summary>
    [Parameter] public string? TestId { get; set; }

    // ── State ─────────────────────────────────────────────────────

    private bool _invalid;
    private string? _lastUserValue;
    private readonly string _inputId = $"url-{Guid.NewGuid():N}";
    private readonly string _errorId = $"url-err-{Guid.NewGuid():N}";

    // ── Lifecycle ─────────────────────────────────────────────────

    protected override void OnParametersSet()
    {
        if (string.IsNullOrWhiteSpace(Value))
        {
            _invalid = false;
        }
        else if (Value != _lastUserValue)
        {
            _invalid = !IsValidUrl(Value);
        }
    }

    // ── Events ────────────────────────────────────────────────────

    private async Task OnInput(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        _lastUserValue = string.IsNullOrEmpty(val) ? null : val;
        _invalid = false;
        await ValueChanged.InvokeAsync(_lastUserValue);
    }

    private void OnBlur()
    {
        if (ReadOnly || string.IsNullOrWhiteSpace(Value)) { _invalid = false; return; }
        _invalid = !IsValidUrl(Value);
    }

    // ── Pure helpers (internal for testability) ───────────────────

    internal static bool IsValidUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return true;
        return Uri.TryCreate(value, UriKind.Absolute, out var uri)
            && (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);
    }
}
