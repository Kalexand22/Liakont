@namespace Stratum.Common.UI.Components

<span class="@_rootClass" data-testid="@(TestId ?? $"reservation-status-chip-{_slug}")" data-fsm-status="@_slug" role="status" aria-label="@($"Statut : {_label}")">
    @if (!string.IsNullOrWhiteSpace(Icon))
    {
        <span class="material-symbols-outlined" aria-hidden="true">@Icon</span>
    }
    <span class="reservation-status-chip__label">@_label</span>
</span>

@code {
    /// <summary>FSM status to render. Required.</summary>
    [Parameter, EditorRequired]
    public ReservationStatus Status { get; set; }

    /// <summary>Chip size — <c>Sm</c> (h-5, 20px) or <c>Md</c> (h-6, 24px). Default <c>Md</c>.</summary>
    [Parameter]
    public ReservationStatusChipSize Size { get; set; } = ReservationStatusChipSize.Md;

    /// <summary>Optional Material Symbol icon name (e.g. <c>schedule</c>, <c>verified</c>).</summary>
    [Parameter]
    public string? Icon { get; set; }

    /// <summary>Optional override for the displayed label. Defaults to a localised FSM name.</summary>
    [Parameter]
    public string? Label { get; set; }

    /// <summary>Optional <c>data-testid</c>. Defaults to <c>reservation-status-chip-&lt;status-slug&gt;</c>.</summary>
    [Parameter]
    public string? TestId { get; set; }

    private string _slug => StatusSlug(Status);
    private string _label => Label ?? StatusLabel(Status);

    private string _rootClass => Size switch
    {
        ReservationStatusChipSize.Sm => $"reservation-status-chip reservation-status-chip--sm reservation-status-chip--{_slug}",
        _                            => $"reservation-status-chip reservation-status-chip--md reservation-status-chip--{_slug}",
    };

    /// <summary>
    /// Maps an enum value to the kebab-case slug used in CSS class names and
    /// <c>data-fsm-status</c> attributes. Public-static so the matching CSS
    /// classes can be generated by tests and so the showcase page does not
    /// have to duplicate the mapping.
    /// </summary>
    public static string StatusSlug(ReservationStatus status) => status switch
    {
        ReservationStatus.Draft          => "draft",
        ReservationStatus.Submitted      => "submitted",
        ReservationStatus.Qualifying     => "qualifying",
        ReservationStatus.UnderReview    => "under-review",
        ReservationStatus.Validated      => "validated",
        ReservationStatus.Reserved       => "reserved",
        ReservationStatus.InPreparation  => "in-preparation",
        ReservationStatus.InExecution    => "in-execution",
        ReservationStatus.Completed      => "completed",
        ReservationStatus.Refused        => "refused",
        ReservationStatus.Cancelled      => "cancelled",
        _                                => "draft",
    };

    /// <summary>
    /// Default human-readable French label for each FSM status. Consumers can
    /// override via the <c>Label</c> parameter when localisation is required.
    /// </summary>
    public static string StatusLabel(ReservationStatus status) => status switch
    {
        ReservationStatus.Draft          => "BROUILLON",
        ReservationStatus.Submitted      => "SOUMISE",
        ReservationStatus.Qualifying     => "QUALIFICATION",
        ReservationStatus.UnderReview    => "INSTRUCTION",
        ReservationStatus.Validated      => "VALIDÉE",
        ReservationStatus.Reserved       => "RÉSERVÉE",
        ReservationStatus.InPreparation  => "PRÉPARATION",
        ReservationStatus.InExecution    => "EN COURS",
        ReservationStatus.Completed      => "TERMINÉE",
        ReservationStatus.Refused        => "REFUSÉE",
        ReservationStatus.Cancelled      => "ANNULÉE",
        _                                => "BROUILLON",
    };

    /// <summary>Sizes available for <see cref="ReservationStatusChip"/>.</summary>
    public enum ReservationStatusChipSize
    {
        /// <summary>20 px tall — for compact tables, inline cells.</summary>
        Sm,

        /// <summary>24 px tall — default, for headers, cards, page chrome.</summary>
        Md,
    }
}
