    private static readonly (ExportFormat Format, string Label, string Value)[] ExportFormatOrder =
    [
        (ExportFormat.Csv, "CSV", "csv"),
        (ExportFormat.Excel, "Excel", "excel"),
        (ExportFormat.Pdf, "PDF", "pdf"),
    ];

    private List<SplitButtonItem> _exportMenuItems => ExportFormatOrder
        .Where(f => ExportFormats.HasFlag(f.Format))
        .Select(f => new SplitButtonItem(f.Label, Value: f.Value))
        .ToList();

