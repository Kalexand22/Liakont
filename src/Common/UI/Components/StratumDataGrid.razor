@namespace Stratum.Common.UI.Components
@typeparam TItem where TItem : notnull
@using Microsoft.Extensions.Localization
@using Microsoft.Extensions.Logging
@using Stratum.Common.Abstractions.Display
@using Stratum.Common.Abstractions.Grid
@using Stratum.Common.UI.Services
@using Stratum.Common.UI.Models
@inject IJSRuntime JS
@inject IDisplayTemplateRegistry DisplayTemplates
@inject IStringLocalizer<SharedResources> L
@inject ILogger<StratumDataGrid<TItem>> Logger

@* StratumDataGrid<TItem> — Stratum wrapper around RadzenDataGrid.
 *
 * All public parameters use Stratum types. Radzen types are mapped internally.
 * Provides ARIA attributes, keyboard navigation (↑↓, Enter, Space/x, Home/End).
 *
 * Usage:
 *   <StratumDataGrid TItem="ProductDto" Data="@products" Loading="@_loading"
 *                    AllowSorting="true" AllowSelection="true"
 *                    OnSortChanged="@HandleSort" OnRowActivated="@GoToProduct"
 *                    AriaLabel="Liste des produits">
 *       <StratumColumn TItem="ProductDto" Property="Name" Title="Nom" Sortable />
 *   </StratumDataGrid>
 *
 * Ref: docs/architecture/ui-architecture-plan.md §4, §5.1.
 *@

<div class="stratum-datagrid-wrapper"
     data-testid="@(TestId ?? "stratum-data-grid")"
     tabindex="-1"
     @onkeydown="HandleKeyDown"
     @ref="_wrapperRef">

    @if (AllowExport || AllowAdvancedFilter || AllowColumnChooser || AllowGroupChooser || OnRefresh.HasDelegate || ToolbarContent is not null || ToolbarEndContent is not null)
    {
        <div class="stratum-datagrid__toolbar" role="toolbar" aria-label="@L["Grid_ToolbarAriaLabel"]">
            <div class="stratum-datagrid__toolbar-start">
                @if (ToolbarContent is not null)
                {
                    @ToolbarContent
                }
                @if (AllowAdvancedFilter)
                {
                    <StratumFilterSplitButton ActiveFilterCount="@CountActiveFilterCriteria()"
                                              SavedFilters="@_toolbarSavedFilters"
                                              OnOpenBuilder="HandleToggleFilterBuilder"
                                              OnLoadSavedFilter="HandleLoadSavedFilterFromToolbarAsync"
                                              OnManageSavedFilters="HandleToggleFilterBuilder"
                                              TestId="filter-btn" />
                }
                @if (AllowColumnChooser && ColumnRegistry is not null)
                {
                    <StratumButton Icon="view_column"
                                   Variant="ButtonVariant.Secondary"
                                   Outline
                                   Size="ButtonSize.Small"
                                   OnClick="@(_ => HandleToggleColumnChooser())"
                                   TestId="column-chooser-btn" />
                }
                @if (AllowGroupChooser && ColumnRegistry is not null)
                {
                    <StratumButton Icon="account_tree"
                                   Text="@(_groupKeys.Count > 0 ? _groupKeys.Count.ToString() : null)"
                                   Variant="@(_groupKeys.Count > 0 ? ButtonVariant.Primary : ButtonVariant.Secondary)"
                                   Outline="@(_groupKeys.Count == 0)"
                                   Size="ButtonSize.Small"
                                   OnClick="@(_ => HandleToggleGroupChooser())"
                                   TestId="group-chooser-btn" />
                }
                @if (OnRefresh.HasDelegate)
                {
                    <StratumButton Icon="refresh"
                                   Variant="ButtonVariant.Secondary"
                                   Outline
                                   Size="ButtonSize.Small"
                                   Title="@L["Grid_RefreshButton"]"
                                   OnClick="@(_ => HandleRefreshAsync())"
                                   TestId="refresh-btn" />
                }
                @if (AllowExport && _exportMenuItems.Count > 0)
                {
                    <StratumSplitButton Text="@L["Grid_ExportButton"]"
                                        Icon="download"
                                        ButtonStyle="ButtonVariant.Secondary"
                                        Outline
                                        Size="ButtonSize.Small"
                                        Disabled="@(Loading || Data is null || Data.Count == 0)"
                                        Items="@_exportMenuItems"
                                        OnClick="@(() => HandleExportAsync(_defaultExportFormat))"
                                        OnItemClick="@HandleExportMenuItemAsync"
                                        TestId="export-btn" />
                }
            </div>
            <div class="stratum-datagrid__toolbar-end">
                @if (ToolbarEndContent is not null)
                {
                    @ToolbarEndContent
                }
            </div>
        </div>
    }

    @if (PreGridContent is not null)
    {
        @PreGridContent
    }

    @if (AllowAdvancedFilter && ColumnRegistry is not null)
    {
        <StratumFilterBuilder TItem="TItem"
                              @bind-Visible="_showFilterBuilder"
                              Registry="@ColumnRegistry"
                              GridKey="@(GridKey ?? string.Empty)"
                              UserId="@UserId"
                              ActiveFilter="@_activeFilter"
                              OnApply="HandleFilterApplied"
                              OnSavedFiltersChanged="RefreshToolbarSavedFiltersAsync"
                              SavedFilterService="@SavedFilterService" />
    }

    @if (AllowColumnChooser && ColumnRegistry is not null)
    {
        <StratumColumnChooser TItem="TItem"
                              @bind-Visible="_showColumnChooser"
                              Registry="@ColumnRegistry"
                              VisibleColumnKeys="@VisibleColumnKeys"
                              OnApply="HandleColumnChooserApplied" />
    }

    @if (AllowGroupChooser && ColumnRegistry is not null)
    {
        <StratumGroupChooser TItem="TItem"
                             @bind-Visible="_showGroupChooser"
                             Registry="@ColumnRegistry"
                             GroupColumnKeys="@_groupKeys"
                             OnApply="HandleGroupChooserApplied" />
    }

    @if (Loading)
    {
        <div class="stratum-datagrid__loading" role="status" aria-label="@(AriaLabel ?? L["Loading"])" aria-busy="true">
            <table class="stratum-datagrid__skeleton" role="presentation">
                <tbody>
                    @for (var s = 0; s < _skeletonRowCount; s++)
                    {
                        <tr class="stratum-datagrid__skeleton-row" aria-hidden="true">
                            @for (var c = 0; c < SkeletonColumnCount; c++)
                            {
                                <td><span class="stratum-datagrid__skeleton-cell"></span></td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (Data is null || Data.Count == 0)
    {
        <div class="stratum-datagrid__empty" role="status">
            @if (EmptyContent is not null)
            {
                @EmptyContent
            }
            else
            {
                <p class="stratum-datagrid__empty-text">Aucun élément.</p>
            }
        </div>
    }
    else
    {
        <CascadingValue Value="@_editingContext" IsFixed="false">
        <CascadingValue Value="@_aggregateContext" IsFixed="false">
        <CascadingValue Value="@UiAttributes" IsFixed="false">
        <Radzen.Blazor.RadzenDataGrid @ref="_radzenGrid"
            @key="@($"{_columnLayoutKey}-e{_editStateVersion}-t{_treeVersion}")"
            TItem="TItem"
            Data="@EffectiveData"
            Count="@EffectiveCount"
            AllowVirtualization="@AllowVirtualization"
            AllowSorting="@AllowSorting"
            AllowMultiColumnSorting="false"
            AllowGrouping="@AllowGrouping"
            AllowColumnResize="@AllowColumnResize"
            ColumnResized="@HandleRadzenColumnResized"
            AllowColumnReorder="@AllowColumnReorder"
            ColumnReordered="@HandleRadzenColumnReordered"
            ShowColumnFooters="@_showColumnFooters"
            SelectionMode="@MapSelectionMode()"
            AllowRowSelectOnRowClick="@(AllowSelection && !UseCustomClickSelection)"
            Value="@_internalSelectedItems"
            RowSelect="@HandleRowSelect"
            RowDeselect="@HandleRowDeselect"
            RowClick="@HandleRowClick"
            RowDoubleClick="@HandleRowDoubleClick"
            RowRender="@OnRowRender"
            Sort="@HandleRadzenSort"
            LoadData="@_radzenLoadData"
            Density="@Radzen.Density.Compact"
            GridLines="@Radzen.DataGridGridLines.Horizontal"
            AllowAlternatingRows="true"
            Groups="@_groupDescriptors"
            class="stratum-datagrid"
            aria-label="@AriaLabel">
            <GroupHeaderTemplate>
                @if (GroupTemplate is not null)
                {
                    @GroupTemplate(new GroupResult(context.Data.Key, context.Data.Count))
                }
                else
                {
                    <span><strong>@context.Data.Key</strong> (@context.Data.Count)</span>
                }
            </GroupHeaderTemplate>
            <Columns>
                @if (ReorderEnabled && !AllowGrouping && string.IsNullOrEmpty(GroupBy) && _groupKeys.Count == 0)
                {
                    <Radzen.Blazor.RadzenDataGridColumn TItem="TItem" Width="40px" Title=""
                        Sortable="false" Filterable="false" Reorderable="false" Frozen="true"
                        CssClass="stratum-datagrid__reorder-cell">
                        <Template Context="item">
                            <span class="stratum-datagrid__drag-handle"
                                  data-testid="drag-handle"
                                  draggable="true"
                                  role="button"
                                  aria-label="@L["Grid_ReorderAriaLabel"]"
                                  tabindex="0">⠿</span>
                        </Template>
                    </Radzen.Blazor.RadzenDataGridColumn>
                }
                @if (_isTreeGrid)
                {
                    <Radzen.Blazor.RadzenDataGridColumn TItem="TItem" Width="40px" Title=""
                        Sortable="false" Filterable="false" Reorderable="false" Frozen="true"
                        CssClass="stratum-datagrid__tree-cell">
                        <Template Context="item">
                            @{
                                var treeLevel = GetTreeLevel(item);
                                var hasChildren = HasTreeChildren(item);
                                var isExpanded = IsTreeNodeExpanded(item);
                            }
                            <span style="padding-left: @(treeLevel * 20)px; display: inline-flex; align-items: center;">
                                @if (hasChildren)
                                {
                                    <button class="stratum-datagrid__tree-toggle"
                                            data-testid="tree-toggle"
                                            @onclick="@(() => ToggleTreeNodeAsync(item))"
                                            aria-expanded="@(isExpanded ? "true" : "false")"
                                            aria-label="@(isExpanded ? L["Grid_TreeCollapse"] : L["Grid_TreeExpand"])"
                                            type="button">
                                        @(isExpanded ? "▼" : "▶")
                                    </button>
                                }
                                else
                                {
                                    <span class="stratum-datagrid__tree-spacer" aria-hidden="true"></span>
                                }
                            </span>
                        </Template>
                    </Radzen.Blazor.RadzenDataGridColumn>
                }
                @if (AllowInlineEdit && EditMode == DataGridEditMode.ButtonOnly)
                {
                    <Radzen.Blazor.RadzenDataGridColumn TItem="TItem" Width="120px" Title=""
                        Sortable="false" Frozen="true">
                        <Template Context="item">
                            @if (_editingItem is not null && EqualityComparer<TItem>.Default.Equals(_editingItem, item))
                            {
                                <StratumButton Text="@L["Save"]"
                                               Variant="ButtonVariant.Success"
                                               Outline
                                               Size="ButtonSize.Small"
                                               CssClass="me-1"
                                               OnClick="@(_ => SaveRowAsync(item))"
                                               TestId="save-row-btn" />
                                <StratumButton Text="@L["Cancel"]"
                                               Variant="ButtonVariant.Secondary"
                                               Outline
                                               Size="ButtonSize.Small"
                                               OnClick="@(_ => CancelEditAsync(item))"
                                               TestId="cancel-row-btn" />
                            }
                            else
                            {
                                <StratumButton Text="@L["Edit"]"
                                               Variant="ButtonVariant.Primary"
                                               Outline
                                               Size="ButtonSize.Small"
                                               OnClick="@(_ => EditRowAsync(item))"
                                               TestId="edit-row-btn" />
                            }
                        </Template>
                    </Radzen.Blazor.RadzenDataGridColumn>
                }
                @if (_resolvedColumns is not null)
                {
                    @foreach (var col in _resolvedColumns)
                    {
                        var colLocal = col;
                        @if (col.IsRelatedEntity && col.RelatedEntityType is not null)
                        {
                            @if (col.AggregateFunc != AggregateFunc.None)
                            {
                                <Radzen.Blazor.RadzenDataGridColumn TItem="TItem"
                                    Title="@col.Title"
                                    Sortable="false"
                                    Width="@GetEffectiveColumnWidth(col)">
                                    <Template Context="item">
                                        <span class="stratum-datagrid__cell"
                                              data-column-key="@colLocal.Key"
                                              data-testid="@($"grid-cell-{colLocal.Key}")"
                                              @oncontextmenu:preventDefault="OnCellContextMenu.HasDelegate"
                                              @oncontextmenu:stopPropagation="OnCellContextMenu.HasDelegate"
                                              @oncontextmenu="@(e => HandleCellContextMenuAsync(e, colLocal, item))">
                                            @FormatRelatedEntity(item, colLocal)
                                        </span>
                                    </Template>
                                    <FooterTemplate>
                                        @RenderDynamicColumnFooter(colLocal)
                                    </FooterTemplate>
                                </Radzen.Blazor.RadzenDataGridColumn>
                            }
                            else
                            {
                                <Radzen.Blazor.RadzenDataGridColumn TItem="TItem"
                                    Title="@col.Title"
                                    Sortable="false"
                                    Width="@GetEffectiveColumnWidth(col)">
                                    <Template Context="item">
                                        <span class="stratum-datagrid__cell"
                                              data-column-key="@colLocal.Key"
                                              data-testid="@($"grid-cell-{colLocal.Key}")"
                                              @oncontextmenu:preventDefault="OnCellContextMenu.HasDelegate"
                                              @oncontextmenu:stopPropagation="OnCellContextMenu.HasDelegate"
                                              @oncontextmenu="@(e => HandleCellContextMenuAsync(e, colLocal, item))">
                                            @FormatRelatedEntity(item, colLocal)
                                        </span>
                                    </Template>
                                </Radzen.Blazor.RadzenDataGridColumn>
                            }
                        }
                        else if (col.AggregateFunc != AggregateFunc.None)
                        {
                            <Radzen.Blazor.RadzenDataGridColumn TItem="TItem"
                                Property="@col.Property"
                                Title="@col.Title"
                                Sortable="@AllowSorting"
                                Width="@GetEffectiveColumnWidth(col)">
                                <Template Context="item">
                                    <span class="stratum-datagrid__cell"
                                          data-column-key="@colLocal.Key"
                                          data-testid="@($"grid-cell-{colLocal.Key}")"
                                          @oncontextmenu:preventDefault="OnCellContextMenu.HasDelegate"
                                          @oncontextmenu:stopPropagation="OnCellContextMenu.HasDelegate"
                                          @oncontextmenu="@(e => HandleCellContextMenuAsync(e, colLocal, item))">
                                        @FormatCellValueForDisplay(NavigatePropertyPath(item, colLocal.Property), colLocal)
                                    </span>
                                </Template>
                                <FooterTemplate>
                                    @RenderDynamicColumnFooter(colLocal)
                                </FooterTemplate>
                            </Radzen.Blazor.RadzenDataGridColumn>
                        }
                        else if (ColumnTemplates is not null && ColumnTemplates.TryGetValue(col.Key, out var customTemplate))
                        {
                            var customTemplateLocal = customTemplate;
                            <Radzen.Blazor.RadzenDataGridColumn TItem="TItem"
                                Property="@col.Property"
                                Title="@col.Title"
                                Sortable="@AllowSorting"
                                Width="@GetEffectiveColumnWidth(col)">
                                <Template Context="item">
                                    <span class="stratum-datagrid__cell"
                                          data-column-key="@colLocal.Key"
                                          data-testid="@($"grid-cell-{colLocal.Key}")"
                                          @oncontextmenu:preventDefault="OnCellContextMenu.HasDelegate"
                                          @oncontextmenu:stopPropagation="OnCellContextMenu.HasDelegate"
                                          @oncontextmenu="@(e => HandleCellContextMenuAsync(e, colLocal, item))">
                                        @customTemplateLocal(item)
                                    </span>
                                </Template>
                            </Radzen.Blazor.RadzenDataGridColumn>
                        }
                        else if (col.DataType == ColumnDataType.Boolean)
                        {
                            <Radzen.Blazor.RadzenDataGridColumn TItem="TItem"
                                Title="@col.Title"
                                Sortable="@AllowSorting"
                                Width="@GetEffectiveColumnWidth(col)">
                                <Template Context="item">
                                    <span class="stratum-datagrid__cell"
                                          data-column-key="@colLocal.Key"
                                          data-testid="@($"grid-cell-{colLocal.Key}")"
                                          @oncontextmenu:preventDefault="OnCellContextMenu.HasDelegate"
                                          @oncontextmenu:stopPropagation="OnCellContextMenu.HasDelegate"
                                          @oncontextmenu="@(e => HandleCellContextMenuAsync(e, colLocal, item))">
                                        @RenderBooleanBadge(item, colLocal)
                                    </span>
                                </Template>
                            </Radzen.Blazor.RadzenDataGridColumn>
                        }
                        else
                        {
                            <Radzen.Blazor.RadzenDataGridColumn TItem="TItem"
                                Property="@col.Property"
                                Title="@col.Title"
                                Sortable="@AllowSorting"
                                Width="@GetEffectiveColumnWidth(col)">
                                <Template Context="item">
                                    <span class="stratum-datagrid__cell"
                                          data-column-key="@colLocal.Key"
                                          data-testid="@($"grid-cell-{colLocal.Key}")"
                                          @oncontextmenu:preventDefault="OnCellContextMenu.HasDelegate"
                                          @oncontextmenu:stopPropagation="OnCellContextMenu.HasDelegate"
                                          @oncontextmenu="@(e => HandleCellContextMenuAsync(e, colLocal, item))">
                                        @FormatCellValueForDisplay(NavigatePropertyPath(item, colLocal.Property), colLocal)
                                    </span>
                                </Template>
                            </Radzen.Blazor.RadzenDataGridColumn>
                        }
                    }
                }
                else
                {
                    @ChildContent
                }
                @if (RowActions is { Count: > 0 })
                {
                    <Radzen.Blazor.RadzenDataGridColumn TItem="TItem" Width="@_actionColumnWidth" Title=""
                        Sortable="false" Filterable="false" Reorderable="false"
                        TextAlign="Radzen.TextAlign.Center" CssClass="stratum-datagrid__action-cell">
                        <Template Context="item">
                            <div class="stratum-datagrid__row-actions" @onclick:stopPropagation="true">
                                @foreach (var action in _quickActions)
                                {
                                    var a = action;
                                    var enabled = a.EvaluateEnabled(item);
                                    <button type="button"
                                            class="stratum-datagrid__quick-action @(a.RequiresConfirmation ? "stratum-datagrid__quick-action--danger" : "")"
                                            title="@a.Label"
                                            disabled="@(!enabled)"
                                            @onclick="@(() => HandleQuickActionAsync(item, a))"
                                            data-testid="@($"quick-action-{a.Id}")">
                                        <StratumIcon Name="@(a.Icon!)" />
                                    </button>
                                }
                                <StratumRowActionMenu TItem="TItem"
                                                      Item="@item"
                                                      RowActions="@RowActions"
                                                      AriaItemLabel="@(RowActionLabelSelector?.Invoke(item))"
                                                      TestId="row-action-menu" />
                            </div>
                        </Template>
                    </Radzen.Blazor.RadzenDataGridColumn>
                }
            </Columns>
        </Radzen.Blazor.RadzenDataGrid>
        </CascadingValue>
        </CascadingValue>
        </CascadingValue>
    }

    @* Quick-action confirmation dialog *@
    @if (_quickActionPending is not null)
    {
        <StratumDialog Title="@L["Grid_Confirmation"]"
                       @bind-Visible="_showQuickActionConfirm"
                       OnClose="CancelQuickAction"
                       Width="400px">
            <ChildContent>
                <p>@string.Format(L["Grid_ConfirmAction"], _quickActionPending.Label)</p>
            </ChildContent>
            <Actions>
                <StratumButton Text="@L["Confirm"]"
                               Variant="ButtonVariant.Danger"
                               Size="ButtonSize.Small"
                               OnClick="@(_ => ConfirmQuickActionAsync())" />
                <StratumButton Text="@L["Cancel"]"
                               Variant="ButtonVariant.Secondary"
                               Size="ButtonSize.Small"
                               OnClick="@(_ => CancelQuickAction())" />
            </Actions>
        </StratumDialog>
    }

    @* GUX03 — persistent cross-page selection bar *@
    @if (PersistentSelection is not null && (_internalSelectedItems.Count > 0 || PersistentSelection.TotalCount > 0))
    {
        <StratumPersistentSelectionBar CurrentCount="@_internalSelectedItems.Count"
                                        TotalCount="@PersistentSelection.TotalCount"
                                        OnAdd="HandlePersistentAdd"
                                        OnRemove="HandlePersistentRemove"
                                        OnView="HandlePersistentViewAsync"
                                        OnClear="HandlePersistentClear"
                                        TestId="@($"{TestId ?? "stratum-data-grid"}-persistent-bar")" />
    }
</div>

@implements IAsyncDisposable

@code {
    // ── References ──────────────────────────────────────────────────
    private Radzen.Blazor.RadzenDataGrid<TItem>? _radzenGrid;
    private ElementReference _wrapperRef;
    private bool _jsRegistered;

    // ── Skeleton defaults ───────────────────────────────────────────
    private const int _skeletonRowCount = 5;

    // ── Quick actions ───────────────────────────────────────────────
    private IReadOnlyList<GridRowAction<TItem>> _quickActions = Array.Empty<GridRowAction<TItem>>();
    private string _actionColumnWidth = "48px";
    private TItem? _quickActionItem;
    private GridRowAction<TItem>? _quickActionPending;
    private bool _showQuickActionConfirm;

    // ── Test ────────────────────────────────────────────────────────

    /// <summary>Optional test identifier. Rendered as <c>data-testid</c> on the root element.</summary>
    [Parameter]
    public string? TestId { get; set; }

    // ── Data ────────────────────────────────────────────────────────

    /// <summary>Items to display. Null or empty triggers the empty state.</summary>
    [Parameter]
    public IReadOnlyList<TItem>? Data { get; set; }

    /// <summary>Total item count for server-side paging.</summary>
    [Parameter]
    public int Count { get; set; }

    /// <summary>
    /// Raised when the grid needs data (server-side paging/sorting).
    /// Uses Stratum <see cref="Models.LoadDataArgs"/>.
    /// </summary>
    [Parameter]
    public EventCallback<LoadDataArgs> LoadData { get; set; }

    // ── Features ────────────────────────────────────────────────────

    /// <summary>Enable virtual scrolling for large datasets.</summary>
    [Parameter]
    public bool AllowVirtualization { get; set; }

    /// <summary>Enable column sorting.</summary>
    [Parameter]
    public bool AllowSorting { get; set; }

    /// <summary>Enable row selection.</summary>
    [Parameter]
    public bool AllowSelection { get; set; }

    /// <summary>Selection mode (One or Multiple). Default: One.</summary>
    [Parameter]
    public SelectionMode SelectionMode { get; set; } = SelectionMode.One;

    /// <summary>
    /// Enable Shift+click range selection and Shift+↑/↓ keyboard range extension.
    /// Only applies when <see cref="SelectionMode"/> is <c>Multiple</c>.
    /// Default: true.
    /// </summary>
    [Parameter]
    public bool EnableShiftRange { get; set; } = true;

    // ── Selection ───────────────────────────────────────────────────

    /// <summary>Currently selected items.</summary>
    [Parameter]
    public IReadOnlyList<TItem>? SelectedItems { get; set; }

    /// <summary>Raised when selection changes.</summary>
    [Parameter]
    public EventCallback<IReadOnlyList<TItem>> OnSelectionChanged { get; set; }

    /// <summary>
    /// Optional session-scoped persistent selection store (GUX03). When supplied,
    /// a floating bar renders at the bottom of the grid with counters and
    /// add/remove/view/clear actions. The binding decouples the grid from the
    /// underlying <c>IPersistentSelectionService&lt;TKey&gt;</c>'s key type.
    /// </summary>
    [Parameter]
    public IPersistentSelectionBinding<TItem>? PersistentSelection { get; set; }

    /// <summary>
    /// Raised when the user clicks "Voir la sélection" in the persistent
    /// selection bar. GUX04 owns the dialog that surfaces the full persistent
    /// set; GUX03 only exposes the button and the event.
    /// </summary>
    [Parameter]
    public EventCallback OnViewPersistentSelection { get; set; }

    /// <summary>Raised when a row is activated (double-click or Enter).</summary>
    [Parameter]
    public EventCallback<TItem> OnRowActivated { get; set; }

    /// <summary>
    /// Raised when the user right-clicks a data cell bound to the dynamic column
    /// registry. Consumers typically use this to open a "Filter on value /
    /// Exclude value / Copy" context menu wired to <c>GridFilterState</c>.
    /// Only fires for columns resolved via <see cref="ColumnRegistry"/>; static
    /// <c>ChildContent</c> columns are not instrumented.
    /// </summary>
    [Parameter]
    public EventCallback<GridCellContextMenuArgs<TItem>> OnCellContextMenu { get; set; }

    // ── Display ─────────────────────────────────────────────────────

    /// <summary>When true, a loading skeleton is shown instead of data.</summary>
    [Parameter]
    public bool Loading { get; set; }

    /// <summary>Custom content to show when Data is empty.</summary>
    [Parameter]
    public RenderFragment? EmptyContent { get; set; }

    /// <summary>Accessible label for the grid.</summary>
    [Parameter]
    public string? AriaLabel { get; set; }

    /// <summary>Column definitions via StratumColumn children.</summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Content rendered at the start (left side) of the grid toolbar.
    /// Use this to inject a search bar or custom controls into the toolbar.
    /// </summary>
    [Parameter]
    public RenderFragment? ToolbarContent { get; set; }

    /// <summary>
    /// Content rendered at the end (right side) of the grid toolbar,
    /// after the built-in Filtres/Colonnes/Export buttons.
    /// Use this to inject a Create button or bulk action controls.
    /// </summary>
    [Parameter]
    public RenderFragment? ToolbarEndContent { get; set; }

    /// <summary>
    /// Content rendered after the toolbar row and before the inline filter bar.
    /// Use this slot to inject a chip bar or a result counter that belongs
    /// between the toolbar and the grid body.
    /// </summary>
    [Parameter]
    public RenderFragment? PreGridContent { get; set; }

    /// <summary>Raised when the user clicks a sortable column header (Stratum event).</summary>
    [Parameter]
    public EventCallback<SortChangedArgs> OnSortChanged { get; set; }

    /// <summary>Number of columns in the loading skeleton. Default: 4.</summary>
    [Parameter]
    public int SkeletonColumnCount { get; set; } = 4;

    // ── Export ─────────────────────────────────────────────────────────

    /// <summary>Show an export toolbar above the grid.</summary>
    [Parameter]
    public bool AllowExport { get; set; }

    /// <summary>Export formats to offer. Default: CSV.</summary>
    [Parameter]
    public ExportFormat ExportFormats { get; set; } = ExportFormat.Csv;

    /// <summary>Base file name for exports (without extension). Default: "export".</summary>
    [Parameter]
    public string ExportFileName { get; set; } = "export";

    /// <summary>
    /// Optional custom export handler. When set, the grid fires this callback
    /// instead of performing the default CSV generation.
    /// </summary>
    [Parameter]
