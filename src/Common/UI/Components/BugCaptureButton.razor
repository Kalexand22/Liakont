@using Microsoft.Extensions.Localization
@using Microsoft.Extensions.Options
@using Stratum.Common.Infrastructure.BugCapture
@using Stratum.Common.UI.Models
@using Stratum.Common.UI.Services
@using Stratum.Common.UI.Services.BugCapture
@implements IDisposable
@inject IBugCaptureService BugCaptureService
@inject IShortcutService ShortcutService
@inject IOptions<CaptureConfiguration> Config
@inject IStringLocalizer<SharedResources> L

@if (Config.Value.Enabled)
{
    @if (_recording)
    {
        @* Minimal stop button while recording — panel is hidden *@
        <button class="bc-button bc-button--recording"
                data-testid="bug-capture-stop-recording"
                @onclick="StopRecordingAndPrepareAsync"
                title="@L["BugCapture_StopRecording"]">
            <svg class="bc-button__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <rect x="6" y="6" width="12" height="12" rx="2" />
            </svg>
            <span class="bc-button__dot bc-button__dot--rec" aria-label="Recording"></span>
        </button>
    }
    else
    {
        <button class="bc-button @(BugCaptureService.State != CaptureState.Idle ? "bc-button--active" : "")"
                data-testid="bug-capture-button"
                @onclick="TogglePanelAsync"
                title="Bug/Feature Capture (Ctrl+Shift+B)">
            <svg class="bc-button__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20 8h-2.81A6 6 0 0 0 7.4 5.18L9 6.78A4 4 0 0 1 16 10v1h4v2h-4v1a4 4 0 0 1-.72 2.29l1.48 1.48A5.99 5.99 0 0 0 18 14h2v-2h-2v-1h2V8zM4 11H2v2h2v1a6 6 0 0 0 1.24 3.77l1.48-1.48A4 4 0 0 1 6 14v-1H4v-2h2v-1a4.02 4.02 0 0 1 .18-1.2L4.69 7.32A6 6 0 0 0 4 10v1zm7.56-6.26l1.97-1.97A6 6 0 0 0 7.4 5.18l1.6 1.6a4.01 4.01 0 0 1 2.56-2.04zm2.88 0a4.01 4.01 0 0 1 2.56 2.04l1.6-1.6A6 6 0 0 0 13.47 2.77l1.97 1.97z"/>
            </svg>
            @if (BugCaptureService.State != CaptureState.Idle)
            {
                <span class="bc-button__dot" aria-label="Capture active"></span>
            }
        </button>
    }

    @* Panel stays in DOM but hidden during recording *@
    @if (_panelOpen || _recording)
    {
        <div class="@(_recording ? "bc-panel-wrapper--hidden" : "")">
            <BugCapturePanel @ref="_panel" OnClose="OnPanelClosedAsync" OnRecordingStarted="OnRecordingStarted" />
        </div>
    }
}

@code {
    private const string ScopeId = "bug-capture-button";
    private const string ToggleCommandId = "bug-capture.toggle";
    private bool _panelOpen;
    private bool _recording;
    private BugCapturePanel? _panel;

    protected override void OnInitialized()
    {
        BugCaptureService.StateChanged += OnServiceStateChanged;
        ShortcutService.PushScope(ScopeId, ShortcutScopeType.Global, [
            new ScopeBinding(ToggleCommandId, "b", ctrl: true, shift: true, handler: TogglePanelAsync)
        ]);
    }

    private async Task TogglePanelAsync()
    {
        if (_recording)
        {
            return;
        }

        if (_panelOpen)
        {
            _panelOpen = false;
            if (BugCaptureService.State != CaptureState.Idle)
            {
                BugCaptureService.CancelSession();
            }
        }
        else
        {
            _panelOpen = true;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnRecordingStarted()
    {
        _recording = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task StopRecordingAndPrepareAsync()
    {
        _recording = false;

        if (_panel is not null)
        {
            await _panel.StopRecordingAndPrepareAsync();
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnPanelClosedAsync()
    {
        _panelOpen = false;
        _recording = false;
        await InvokeAsync(StateHasChanged);
    }

    private void OnServiceStateChanged(object? sender, EventArgs e)
        => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        BugCaptureService.StateChanged -= OnServiceStateChanged;
        ShortcutService.PopScope(ScopeId);
    }
}
