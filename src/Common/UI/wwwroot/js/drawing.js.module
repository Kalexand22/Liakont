// drawing.js.module — Canvas drawing / signature widget for DrawingField.razor
// Pattern: ES module loaded via IJSRuntime.InvokeAsync<IJSObjectReference>("import", ...)
// No external dependencies — Canvas 2D API only.

/** @type {Map<HTMLCanvasElement, CanvasState>} */
const _canvasState = new Map();

/**
 * Initialises the canvas and registers mouse/touch drawing event listeners.
 * @param {HTMLCanvasElement} canvas
 * @param {{ penColor: string, penWidth: number, backgroundColor: string, mode: string, maxUndoSteps: number, exportOnStroke: boolean, disabled: boolean }} options
 * @param {any} dotNetRef  DotNetObjectReference<DrawingField>
 */
export function initCanvas(canvas, options, dotNetRef) {
    const ctx = canvas.getContext('2d');

    // Fill background
    ctx.fillStyle = options.backgroundColor;
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    const state = {
        ctx,
        options: { ...options },
        dotNetRef,
        undoStack: [],
        redoStack: [],
        drawing: false,
        listeners: {},
    };

    _applyContextStyle(state);

    if (!options.disabled) {
        const onMouseDown  = (e) => _startDraw(canvas, state, e);
        const onMouseMove  = (e) => _continueDraw(canvas, state, e);
        const onMouseUp    = ()  => _endDraw(canvas, state);
        const onMouseLeave = ()  => _endDraw(canvas, state);
        const onTouchStart = (e) => { e.preventDefault(); _startDraw(canvas, state, e.touches[0]); };
        const onTouchMove  = (e) => { e.preventDefault(); _continueDraw(canvas, state, e.touches[0]); };
        const onTouchEnd   = (e) => { e.preventDefault(); _endDraw(canvas, state); };

        canvas.addEventListener('mousedown',  onMouseDown);
        canvas.addEventListener('mousemove',  onMouseMove);
        canvas.addEventListener('mouseup',    onMouseUp);
        canvas.addEventListener('mouseleave', onMouseLeave);
        canvas.addEventListener('touchstart', onTouchStart, { passive: false });
        canvas.addEventListener('touchmove',  onTouchMove,  { passive: false });
        canvas.addEventListener('touchend',   onTouchEnd,   { passive: false });

        state.listeners = { onMouseDown, onMouseMove, onMouseUp, onMouseLeave, onTouchStart, onTouchMove, onTouchEnd };
    }

    _canvasState.set(canvas, state);
}

/**
 * Loads a PNG Base64 image into the canvas.
 * @param {HTMLCanvasElement} canvas
 * @param {string} base64  PNG Base64 without data-URL prefix
 * @returns {Promise<void>}
 */
export function loadImage(canvas, base64) {
    const ctx = canvas.getContext('2d');
    return new Promise((resolve, reject) => {
        const img = new Image();
        img.onload = () => {
            ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
            resolve();
        };
        img.onerror = () => reject(new Error('drawing.js.module: failed to load image'));
        img.src = 'data:image/png;base64,' + base64;
    });
}

/**
 * Exports the current canvas as a PNG Base64 string (without data-URL prefix).
 * @param {HTMLCanvasElement} canvas
 * @returns {string}
 */
export function exportPng(canvas) {
    return canvas.toDataURL('image/png').replace('data:image/png;base64,', '');
}

/**
 * Clears the canvas, empties undo/redo stacks, invokes OnCanvasChanged(null).
 * @param {HTMLCanvasElement} canvas
 * @param {string} backgroundColor
 */
export function clear(canvas, backgroundColor) {
    const state = _canvasState.get(canvas);
    if (!state) return;

    state.ctx.fillStyle = backgroundColor;
    state.ctx.fillRect(0, 0, canvas.width, canvas.height);
    state.undoStack = [];
    state.redoStack = [];
    _applyContextStyle(state);
    _notifyUndoState(state);
    _invokeAsync(state.dotNetRef, 'OnCanvasChanged', null);
}

/**
 * Undoes the last stroke.
 * @param {HTMLCanvasElement} canvas
 * @returns {Promise<void>}
 */
export async function undo(canvas) {
    const state = _canvasState.get(canvas);
    if (!state || state.drawing || state.undoStack.length === 0) return;

    const prev = state.undoStack[state.undoStack.length - 1];
    const base64 = prev.replace('data:image/png;base64,', '');
    const current = canvas.toDataURL('image/png');

    try {
        await loadImage(canvas, base64);
    } catch {
        return;
    }

    state.undoStack.pop();
    state.redoStack.push(current);
    _applyContextStyle(state);

    _notifyUndoState(state);
    _invokeAsync(state.dotNetRef, 'OnCanvasChanged', base64);
}

/**
 * Redoes a previously undone stroke.
 * @param {HTMLCanvasElement} canvas
 * @returns {Promise<void>}
 */
export async function redo(canvas) {
    const state = _canvasState.get(canvas);
    if (!state || state.drawing || state.redoStack.length === 0) return;

    const next = state.redoStack[state.redoStack.length - 1];
    const base64 = next.replace('data:image/png;base64,', '');
    const current = canvas.toDataURL('image/png');

    try {
        await loadImage(canvas, base64);
    } catch {
        return;
    }

    state.redoStack.pop();
    state.undoStack.push(current);
    if (state.undoStack.length > state.options.maxUndoSteps) {
        state.undoStack.shift();
    }
    _applyContextStyle(state);

    _notifyUndoState(state);
    _invokeAsync(state.dotNetRef, 'OnCanvasChanged', base64);
}

/**
 * Updates pen options on the canvas (partial update).
 * @param {HTMLCanvasElement} canvas
 * @param {{ penColor?: string, penWidth?: number }} options
 */
export function updateOptions(canvas, options) {
    const state = _canvasState.get(canvas);
    if (!state) return;

    if (options.penColor !== undefined) state.options.penColor = options.penColor;
    if (options.penWidth !== undefined) state.options.penWidth = options.penWidth;
    _applyContextStyle(state);
}

/**
 * Removes all event listeners and cleans up state for this canvas.
 * @param {HTMLCanvasElement} canvas
 */
export function destroyCanvas(canvas) {
    const state = _canvasState.get(canvas);
    if (!state) return;

    const { listeners: l } = state;
    if (l.onMouseDown) {
        canvas.removeEventListener('mousedown',  l.onMouseDown);
        canvas.removeEventListener('mousemove',  l.onMouseMove);
        canvas.removeEventListener('mouseup',    l.onMouseUp);
        canvas.removeEventListener('mouseleave', l.onMouseLeave);
        canvas.removeEventListener('touchstart', l.onTouchStart);
        canvas.removeEventListener('touchmove',  l.onTouchMove);
        canvas.removeEventListener('touchend',   l.onTouchEnd);
    }

    _canvasState.delete(canvas);
}

// ── Private helpers ───────────────────────────────────────────────────────────

function _applyContextStyle(state) {
    const { ctx, options } = state;
    const color = options.mode === 'signature' ? '#000000' : options.penColor;
    const width = options.mode === 'signature' ? 1.5 : options.penWidth;
    ctx.strokeStyle = color;
    ctx.fillStyle   = color;
    ctx.lineWidth   = width;
    ctx.lineCap     = 'round';
    ctx.lineJoin    = 'round';
}

function _getPos(canvas, e) {
    const rect = canvas.getBoundingClientRect();
    return {
        x: (e.clientX - rect.left) * (canvas.width  / rect.width),
        y: (e.clientY - rect.top)  * (canvas.height / rect.height),
    };
}

function _startDraw(canvas, state, e) {
    if (state.options.disabled) return;
    state.drawing = true;

    const pos = _getPos(canvas, e);

    // Capture state BEFORE the new stroke for Undo.
    const snapshot = canvas.toDataURL('image/png');
    state.undoStack.push(snapshot);
    if (state.undoStack.length > state.options.maxUndoSteps) {
        state.undoStack.shift();
    }
    state.redoStack = [];

    // Draw initial dot (handles click-without-drag).
    state.ctx.beginPath();
    state.ctx.arc(pos.x, pos.y, state.ctx.lineWidth / 2, 0, Math.PI * 2);
    state.ctx.fill();

    // Begin line path.
    state.ctx.beginPath();
    state.ctx.moveTo(pos.x, pos.y);
}

function _continueDraw(canvas, state, e) {
    if (!state.drawing) return;
    const pos = _getPos(canvas, e);
    state.ctx.lineTo(pos.x, pos.y);
    state.ctx.stroke();
}

function _endDraw(canvas, state) {
    if (!state.drawing) return;
    state.drawing = false;
    state.ctx.beginPath();

    _notifyUndoState(state);

    if (state.options.exportOnStroke) {
        const png = exportPng(state.ctx.canvas);
        _invokeAsync(state.dotNetRef, 'OnStrokeCompleted', png);
    }
}

function _notifyUndoState(state) {
    _invokeAsync(
        state.dotNetRef,
        'OnUndoRedoStateChanged',
        state.undoStack.length > 0,
        state.redoStack.length > 0,
    );
}

function _invokeAsync(dotNetRef, method, ...args) {
    if (!dotNetRef) return;
    dotNetRef.invokeMethodAsync(method, ...args).catch(() => {});
}
