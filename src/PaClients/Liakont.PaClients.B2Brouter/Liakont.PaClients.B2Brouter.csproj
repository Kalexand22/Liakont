<Project Sdk="Microsoft.NET.Sdk">
  <ItemGroup>
    <!-- DI abstractions pour l'extension AddB2BrouterPaClient + Microsoft.Extensions.Http pour
         IHttpClientFactory / AddHttpClient (client HTTP nommé par compte, TLS 1.2/1.3 — F05 §5).
         Aucun package NuGet nouveau, aucun ADR : versions gérées centralement (Directory.Packages.props,
         repo-standards §4). System.Text.Json est dans la BCL net10.0 (aucune dépendance Newtonsoft —
         la note F05 §5 « Newtonsoft » visait l'implémentation net48 PRÉ-pivot, caduque). -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Http" />
  </ItemGroup>
  <ItemGroup>
    <!-- Un plug-in PA ne référence QUE Transmission.Contracts (+ Common) — jamais un autre plug-in,
         jamais un module métier, jamais l'Infrastructure du module (blueprint.md §2 règle 4 ;
         module-rules §6 ; CLAUDE.md n°6/16). Frontière verrouillée par B2BrouterBoundaryTests.
         PivotDocumentDto arrive transitivement via Transmission.Contracts (qui référence
         Liakont.Agent.Contracts) — aucune ProjectReference directe interdite n'est déclarée. -->
    <ProjectReference Include="../../Modules/Transmission/Contracts/Liakont.Modules.Transmission.Contracts.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- Les types « fil » B2Brouter (DTOs de payload, client, builder, mapper) sont internal —
         AUCUN type propriétaire B2Brouter n'est exposé hors de l'assembly (acceptance PAB01,
         vérifié par B2BrouterBoundaryTests). Les tests les exercent via InternalsVisibleTo. -->
    <InternalsVisibleTo Include="Liakont.PaClients.B2Brouter.Tests.Unit" />
  </ItemGroup>
</Project>
