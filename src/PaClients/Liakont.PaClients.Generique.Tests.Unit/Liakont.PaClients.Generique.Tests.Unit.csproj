<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <!-- Mêmes relaxations de conventions xUnit que les autres projets de test de plug-in PA
         (dossier ne commençant pas par « Tests. ») — cf. Liakont.PaClients.SuperPdp.Tests.Unit. -->
    <NoWarn>$(NoWarn);CA1707;SA1116;SA1117;SA1202;SA1210;SA1512</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" PrivateAssets="all" />
    <PackageReference Include="FluentAssertions" />
    <!-- Gardes de frontière + encapsulation du plug-in (F16 §6 ; modèle SuperPdpBoundaryTests). -->
    <PackageReference Include="NetArchTest.Rules" />
  </ItemGroup>
  <ItemGroup>
    <!-- ServiceCollection pour tester AddGeneriquePaClient + résolution via le registre. -->
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../Liakont.PaClients.Generique/Liakont.PaClients.Generique.csproj" />
    <!-- Le registre du module (AddTransmissionModule) pour prouver la résolution du plug-in par clé. -->
    <ProjectReference Include="../../Modules/Transmission/Infrastructure/Liakont.Modules.Transmission.Infrastructure.csproj" />
    <!-- PivotDocumentDto pour construire des documents de test (facture fictive). -->
    <ProjectReference Include="../../Contracts/Liakont.Agent.Contracts/Liakont.Agent.Contracts.csproj" />
  </ItemGroup>
</Project>
