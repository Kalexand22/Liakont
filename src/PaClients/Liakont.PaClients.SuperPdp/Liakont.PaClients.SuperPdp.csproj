<Project Sdk="Microsoft.NET.Sdk">
  <ItemGroup>
    <!-- DI abstractions pour l'extension AddSuperPdpPaClient + Microsoft.Extensions.Http pour
         IHttpClientFactory / AddHttpClient (client HTTP nommé par compte, TLS 1.2/1.3 — F14 §7).
         Aucun package NuGet nouveau, aucun ADR : versions gérées centralement (Directory.Packages.props,
         repo-standards §4). System.Text.Json est dans la BCL net10.0. -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Http" />
  </ItemGroup>
  <ItemGroup>
    <!-- Un plug-in PA ne référence QUE Transmission.Contracts (+ Common) — jamais un autre plug-in,
         jamais un module métier, jamais l'Infrastructure du module (blueprint.md §2 règle 4 ;
         module-rules §6 ; CLAUDE.md n°6/16). Frontière verrouillée par SuperPdpBoundaryTests.
         PivotDocumentDto arrive transitivement via Transmission.Contracts (qui référence
         Liakont.Agent.Contracts) — aucune ProjectReference directe interdite n'est déclarée. -->
    <ProjectReference Include="../../Modules/Transmission/Contracts/Liakont.Modules.Transmission.Contracts.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- Les types « fil » Super PDP (DTOs de payload, client OAuth, builder, mapper) sont internal —
         AUCUN type propriétaire Super PDP n'est exposé hors de l'assembly (acceptance PAS02,
         vérifié par SuperPdpBoundaryTests). Les tests les exercent via InternalsVisibleTo. -->
    <InternalsVisibleTo Include="Liakont.PaClients.SuperPdp.Tests.Unit" />
  </ItemGroup>
</Project>
