<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <!-- Mêmes relaxations de conventions xUnit que les autres projets de test de plug-in (noms de tests
         avec underscores, ordonnancement souple) — cf. Liakont.PaClients.B2Brouter.Tests.Unit. -->
    <NoWarn>$(NoWarn);CA1707;SA1116;SA1117;SA1202;SA1210;SA1512</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" PrivateAssets="all" />
    <PackageReference Include="FluentAssertions" />
    <!-- Gardes de frontière du plug-in (INV-YOUSIGN-2). -->
    <PackageReference Include="NetArchTest.Rules" />
  </ItemGroup>
  <ItemGroup>
    <!-- ServiceCollection / AddHttpClient pour tester AddYousignSignatureProvider + le handler anti-SSRF. -->
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../Liakont.SignatureProviders.Yousign/Liakont.SignatureProviders.Yousign.csproj" />
  </ItemGroup>
</Project>
