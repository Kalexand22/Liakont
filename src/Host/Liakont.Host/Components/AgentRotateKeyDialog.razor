@namespace Liakont.Host.Components
@using Liakont.Modules.Ingestion.Contracts.DTOs
@using Stratum.Common.UI.Components
@using Stratum.Common.UI.Models

@* Dialogue de RENOUVELLEMENT de clé d'un agent (WEB09). Composant PUR : phase 1 = confirmation (conséquence
 * explicite : l'ancienne clé est invalidée immédiatement), phase 2 = affichage de la nouvelle clé une seule
 * fois (avertissement + copie). 100 % français. *@

@if (IsOpen)
{
    <div class="liakont-agent-dialog" role="dialog" aria-label="Renouveler la clé de l'agent" data-testid="agent-rotate-dialog">
        <div class="liakont-agent-dialog__panel">
            @if (IssuedKey is { } key)
            {
                @* Phase 2 : la NOUVELLE clé n'existe que dans CE rendu. *@
                <h2 class="liakont-agent-dialog__title">Nouvelle clé de l'agent « @AgentName »</h2>
                <div class="liakont-agent-dialog__alert" role="alert" data-testid="agent-rotate-key-warning">
                    Cette clé ne pourra plus être affichée — copiez-la maintenant et mettez à jour l'agent.
                    L'ancienne clé est désormais invalide.
                </div>
                <div class="liakont-agent-dialog__key-panel" data-testid="agent-rotate-key-panel">
                    <code class="liakont-agent-dialog__key" data-testid="agent-rotate-key">@key.FullKey</code>
                </div>
                <div class="liakont-agent-dialog__actions">
                    <StratumButton Text="Copier la clé"
                                   Variant="ButtonVariant.Secondary"
                                   Outline
                                   Size="ButtonSize.Small"
                                   OnClick="@(() => OnCopyKey.InvokeAsync(key.FullKey))"
                                   TestId="agent-rotate-copy" />
                    <StratumButton Text="J'ai copié la clé — fermer"
                                   Variant="ButtonVariant.Primary"
                                   Size="ButtonSize.Small"
                                   OnClick="@(() => OnClose.InvokeAsync())"
                                   TestId="agent-rotate-close" />
                </div>
            }
            else
            {
                @* Phase 1 : confirmation. *@
                <h2 class="liakont-agent-dialog__title">Renouveler la clé de l'agent « @AgentName »</h2>
                <div class="liakont-agent-dialog__alert" role="alert" data-testid="agent-rotate-consequence">
                    Une nouvelle clé sera émise et affichée une seule fois. L'ancienne clé sera invalidée
                    IMMÉDIATEMENT : l'agent ne pourra plus pousser de documents tant que sa nouvelle clé ne lui
                    aura pas été transmise.
                </div>

                @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                {
                    <div class="liakont-agent-dialog__alert" role="alert" data-testid="agent-rotate-error">@ErrorMessage</div>
                }

                <div class="liakont-agent-dialog__actions">
                    <StratumButton Text="@(Busy ? "Renouvellement…" : "Renouveler la clé")"
                                   Variant="ButtonVariant.Warning"
                                   Size="ButtonSize.Small"
                                   Disabled="@Busy"
                                   OnClick="@(() => OnConfirm.InvokeAsync())"
                                   TestId="agent-rotate-confirm" />
                    <StratumButton Text="Annuler"
                                   Variant="ButtonVariant.Secondary"
                                   Outline
                                   Size="ButtonSize.Small"
                                   Disabled="@Busy"
                                   OnClick="@(() => OnCancel.InvokeAsync())"
                                   TestId="agent-rotate-cancel" />
                </div>
            }
        </div>
    </div>
}

@code {
    /// <summary><c>true</c> quand le dialogue est ouvert.</summary>
    [Parameter]
    public bool IsOpen { get; set; }

    /// <summary>Nom de l'agent ciblé (affiché dans la conséquence — CLAUDE.md n°12).</summary>
    [Parameter]
    public string AgentName { get; set; } = string.Empty;

    /// <summary>Action en cours (désactive les boutons).</summary>
    [Parameter]
    public bool Busy { get; set; }

    /// <summary>Message d'erreur français à afficher, ou <c>null</c>.</summary>
    [Parameter]
    public string? ErrorMessage { get; set; }

    /// <summary>Clé émise (phase 2) : quand renseignée, le dialogue affiche la nouvelle clé au lieu de la confirmation.</summary>
    [Parameter]
    public AgentKeyIssuedDto? IssuedKey { get; set; }

    /// <summary>Déclenché à la confirmation du renouvellement.</summary>
    [Parameter]
    public EventCallback OnConfirm { get; set; }

    /// <summary>Déclenché à l'annulation (phase 1).</summary>
    [Parameter]
    public EventCallback OnCancel { get; set; }

    /// <summary>Déclenché à la fermeture après affichage de la clé (phase 2).</summary>
    [Parameter]
    public EventCallback OnClose { get; set; }

    /// <summary>Déclenché quand l'opérateur demande la copie de la clé (le parent porte le presse-papiers).</summary>
    [Parameter]
    public EventCallback<string> OnCopyKey { get; set; }
}
