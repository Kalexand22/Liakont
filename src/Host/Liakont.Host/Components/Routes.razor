@using Stratum.Modules.Identity.Web
@using Stratum.Modules.Notification.Web
@using Stratum.Modules.Audit.Web
@using Stratum.Modules.Job.Web

<Router AppAssembly="typeof(App).Assembly"
        AdditionalAssemblies="new[] { typeof(IdentityEndpointMapping).Assembly, typeof(NotificationEndpointMapping).Assembly, typeof(AuditNavSectionProvider).Assembly, typeof(JobNavSectionProvider).Assembly }">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.ErpShellLayout)">
            <NotAuthorized>
                <RedirectToLogin />
            </NotAuthorized>
            <Authorizing>
                <p>Checking authentication...</p>
            </Authorizing>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    @* Route inconnue : message « page introuvable » explicite dans le shell, jamais une page vide (FIX07c).
       Garde d'authentification cohérente avec la branche Found (un visiteur non connecté est redirigé vers
       la connexion, comme pour toute page de la console). *@
    <NotFound>
        <AuthorizeView>
            <Authorized>
                <LayoutView Layout="typeof(Layout.ErpShellLayout)">
                    <PageNotFound />
                </LayoutView>
            </Authorized>
            <NotAuthorized>
                <RedirectToLogin />
            </NotAuthorized>
        </AuthorizeView>
    </NotFound>
</Router>
