@using Stratum.Modules.Identity.Web
@using Stratum.Modules.Notification.Web
@using Stratum.Modules.Audit.Web
@using Stratum.Modules.Job.Web

<Router AppAssembly="typeof(App).Assembly"
        AdditionalAssemblies="new[] { typeof(IdentityEndpointMapping).Assembly, typeof(NotificationEndpointMapping).Assembly, typeof(AuditNavSectionProvider).Assembly, typeof(JobNavSectionProvider).Assembly }">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.ErpShellLayout)">
            <NotAuthorized>
                <RedirectToLogin />
            </NotAuthorized>
            <Authorizing>
                <p>Checking authentication...</p>
            </Authorizing>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
