@page "/documents/{Id:guid}"
@rendermode InteractiveServer
@attribute [Authorize]
@using Liakont.Host.Components
@using Liakont.Host.Documents
@using Liakont.Host.Security
@using Stratum.Common.Abstractions.Security
@using Stratum.Common.UI.Models
@inject IDocumentDetailConsoleQueries DetailQueries
@inject IDocumentControlActions ControlActions
@inject IDocumentSendActions SendActions
@inject IPermissionService Permissions
@inject ILogger<DocumentDetail> Logger

@* Page détail document (WEB03a + actions WEB03b/c, F10 §2.3). Page MINCE : elle charge le détail assemblé via
 * IDocumentDetailConsoleQueries (aucun accès base direct, aucune logique métier) et délègue le rendu à la vue
 * pure DocumentDetailView (CONTENU seul : onglets Contenu / Contrôles / Historique / Archive). Les ACTIONS
 * (verdict garde-fou B2B/B2C, re-vérification — WEB03b ; envoi) sont présentées dans une barre d'actions
 * PERMANENTE en tête de fiche (DocumentActionBar, FIX04b) — plus aucune action enfouie dans un onglet — et
 * orchestrées ICI via IDocumentControlActions / IDocumentSendActions (appels in-process) ; les actions de
 * résolution terminale (WEB03c) sont déléguées au composant interactif DocumentResolutionActions, lui aussi en
 * tête de fiche. Après TOUTE action, la page recharge le détail (état + historique à jour, sans rechargement de
 * page). Les boutons d'action ne sont proposés qu'aux porteurs de la permission liakont.actions (la page reste
 * consultable en lecture sinon). *@

<PageTitle>Détail du document — Liakont</PageTitle>

<div class="liakont-doc-detail-page">
    <div class="liakont-doc-detail-page__head">
        <StratumButton Text="Retour à la liste"
                       Variant="ButtonVariant.Secondary"
                       Outline
                       Size="ButtonSize.Small"
                       Href="/documents"
                       TestId="document-detail-back" />
    </div>

    @if (_loadFailed)
    {
        <div class="liakont-doc-detail-page__alert" role="alert" data-testid="document-detail-error">
            Impossible de charger ce document pour le moment. Réessayez plus tard.
        </div>
    }
    else if (_notFound)
    {
        <div class="liakont-doc-detail-page__alert" role="alert" data-testid="document-detail-notfound">
            Ce document est introuvable. Il a peut-être été remplacé, ou il n'appartient pas à ce tenant.
        </div>
    }
    else if (_model is null)
    {
        <p data-testid="document-detail-loading">Chargement…</p>
    }
    else
    {
        <h1 data-testid="document-detail-title">Document @_model.Document.DocumentNumber</h1>

        @* Barre d'actions PERMANENTE en tête de fiche (FIX04b) : verdict garde-fou B2B/B2C, re-vérification et
         * envoi — selon l'état du document et la permission liakont.actions. Plus aucune action enfouie dans un
         * onglet ; le message de retour de la dernière action est affiché juste en dessous, toujours visible. *@
        <DocumentActionBar Model="_model"
                           CanAct="_canAct"
                           ActionInProgress="_actionInProgress"
                           OnConfirmB2c="@(() => SubmitVerdictAsync(ConsoleVerdict.ConfirmIndividualB2c))"
                           OnHandleManually="@(() => SubmitVerdictAsync(ConsoleVerdict.HandleManuallyB2b))"
                           OnRecheck="RecheckAsync"
                           OnSend="SendDocumentAsync" />

        @if (!string.IsNullOrWhiteSpace(_actionFeedback))
        {
            <div class="liakont-doc-detail__action-feedback @(_actionFailed ? "liakont-doc-detail__action-feedback--error" : "liakont-doc-detail__action-feedback--ok")"
                 role="status"
                 data-testid="document-detail-action-feedback">
                @_actionFeedback
            </div>
        }

        @* Actions de RÉSOLUTION TERMINALE (traiter manuellement hors passerelle, lier au remplaçant) : panneaux
         * de saisie multi-étapes, eux aussi en tête de fiche — jamais enfouis dans un onglet (WEB03c). *@
        <DocumentResolutionActions DocumentId="_model.Document.Id"
                                   DocumentNumber="@_model.Document.DocumentNumber"
                                   State="@_model.Document.State"
                                   OnResolved="ReloadAsync" />

        <DocumentDetailView Model="_model" />
    }
</div>

@code {
    /// <summary>Identifiant du document (segment de route). Charge le détail au changement d'identifiant.</summary>
    [Parameter]
    public Guid Id { get; set; }

    private Guid _loadedId;
    private DocumentDetailViewModel? _model;
    private bool _notFound;
    private bool _loadFailed;

    private bool _canAct;
    private bool _actionInProgress;
    private string? _actionFeedback;
    private bool _actionFailed;

    protected override void OnInitialized()
    {
        // Permission d'action opérateur : les boutons garde-fou / re-vérification ne sont proposés qu'aux
        // porteurs de liakont.actions (l'application réelle reste serveur — service in-process tenant-scopé).
        _canAct = Permissions.HasPermission(LiakontPermissions.Actions);
    }

    protected override async Task OnParametersSetAsync()
    {
        // Charge une seule fois par identifiant distinct (un re-rendu sans changement d'Id ne recharge pas).
        if (Id == _loadedId)
        {
            return;
        }

        _loadedId = Id;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _model = null;
        _notFound = false;
        _loadFailed = false;
        _actionFeedback = null;
        _actionFailed = false;

        try
        {
            var model = await DetailQueries.GetDetailAsync(Id);
            if (model is null)
            {
                _notFound = true;
            }
            else
            {
                _model = model;
            }
        }
        catch (Exception ex)
        {
            // L'échec reste VISIBLE pour l'opérateur (bandeau) et tracé — jamais avalé en silence.
            _loadFailed = true;
            Logger.LogError(ex, "Failed to load the document detail page for document {DocumentId}.", Id);
        }
    }

    /// <summary>Pose un verdict du garde-fou B2B/B2C puis recharge le détail (historique + contrôles à jour).</summary>
    private Task SubmitVerdictAsync(ConsoleVerdict verdict) =>
        RunActionAsync(async () =>
        {
            var result = await ControlActions.SubmitVerdictAsync(Id, verdict);
            return (result.Success, result.Message);
        });

    /// <summary>Re-vérifie le document bloqué puis recharge le détail (le nouvel état / motif s'affiche immédiatement).</summary>
    private Task RecheckAsync() =>
        RunActionAsync(async () =>
        {
            var result = await ControlActions.RecheckAsync(Id);
            return (result.Success, result.Message);
        });

    /// <summary>
    /// Déclenche l'envoi du document (prêt à l'envoi) depuis la barre d'actions, puis recharge le détail.
    /// Réutilise le chemin d'envoi EXISTANT <see cref="IDocumentSendActions.SendSelectionAsync"/> (sélection
    /// d'un seul document) — AUCUN second chemin d'envoi : la garde d'état <c>ReadyToSend</c> et la permission
    /// <c>liakont.actions</c> sont appliquées côté SERVEUR par le service (le bouton n'est qu'un raccourci
    /// visible). Le résultat (succès ou motif de refus français) s'affiche dans le bandeau d'action.
    /// </summary>
    private Task SendDocumentAsync() =>
        RunActionAsync(async () =>
        {
            var result = await SendActions.SendSelectionAsync(new[] { Id });
            return (result.Success, result.Message);
        });

    /// <summary>
    /// Exécute une action de la barre d'actions (verdict, re-vérification, envoi) : désactive les boutons le
    /// temps de l'appel, mémorise le message opérateur (succès ou refus) et RECHARGE le détail pour refléter
    /// l'état, l'historique et les contrôles sans rechargement de page. Tout échec inattendu reste VISIBLE
    /// (message) et tracé — jamais avalé.
    /// </summary>
    private async Task RunActionAsync(Func<Task<(bool Success, string Message)>> action)
    {
        if (_actionInProgress || _model is null)
        {
            return;
        }

        _actionInProgress = true;
        _actionFeedback = null;
        _actionFailed = false;

        try
        {
            var (success, message) = await action();
            _actionFeedback = message;
            _actionFailed = !success;
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _actionFailed = true;
            _actionFeedback = "L'action n'a pas pu être effectuée pour le moment. Réessayez plus tard.";
            Logger.LogError(ex, "Console document action failed for document {DocumentId}.", Id);
        }
        finally
        {
            _actionInProgress = false;
        }
    }

    /// <summary>
    /// Recharge le détail assemblé (re-lecture tenant-scopée) après une action — verdict/re-vérification (WEB03b)
    /// ou résolution terminale (WEB03c) : l'état, la piste d'audit (nouvel événement) et l'éventuel lien vers le
    /// remplaçant reflètent alors l'action. Ne masque pas la fiche si la re-lecture échoue (le message reste visible).
    /// </summary>
    private async Task ReloadAsync()
    {
        try
        {
            var model = await DetailQueries.GetDetailAsync(Id);
            if (model is not null)
            {
                _model = model;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to reload the document detail after an action for document {DocumentId}.", Id);
        }
    }
}
