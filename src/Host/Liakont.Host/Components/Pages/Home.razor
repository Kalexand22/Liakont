@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@using Liakont.Host.Dashboard
@using Liakont.Host.Security
@using Microsoft.AspNetCore.Components.Authorization
@inject IDashboardQueries DashboardQueries
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<Home> Logger

<PageTitle>Tableau de bord — Liakont</PageTitle>

<h1 class="visually-hidden">Tableau de bord</h1>

@if (_loadFailed)
{
    <LiakontAlert TestId="dashboard-error">
        Impossible de charger le tableau de bord pour le moment. Réessayez plus tard.
    </LiakontAlert>
}
else if (_model is null)
{
    <LiakontLoading TestId="dashboard-loading" />
}
else
{
    <DashboardView Model="_model" OnYearStateSelected="OnYearStateSelected" />
}

@code {
    private DashboardViewModel? _model;
    private bool _loadFailed;

    // Drill-down du graphique « Année en cours » : la vue (pure) remonte l'état cliqué, la page
    // navigue vers la liste filtrée sur le périmètre année (mêmes bornes que le compteur).
    private void OnYearStateSelected(string state)
    {
        if (_model is { } model)
        {
            Nav.NavigateTo(model.CurrentYear.DocumentsUrl(state));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // RB1 — un super-admin (stratum-admin) opère en cross-tenant : le tableau de bord « / » est
        // tenant-scopé et n'a pas de sens pour lui. On le redirige vers la Supervision (vue d'ensemble
        // cross-tenant), son vrai tableau de bord. Aucune requête tenant n'est émise pour lui.
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (SuperAdminRoles.IsSuperAdmin(authState.User))
        {
            Nav.NavigateTo("/supervision");
            return;
        }

        try
        {
            _model = await DashboardQueries.GetDashboardAsync();
        }
        catch (Exception ex)
        {
            // L'échec reste VISIBLE pour l'opérateur (bandeau) et tracé — jamais avalé en silence.
            _loadFailed = true;
            Logger.LogError(ex, "Failed to load the Liakont home dashboard.");
        }
    }
}
