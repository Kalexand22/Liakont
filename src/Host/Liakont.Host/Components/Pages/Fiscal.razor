@page "/parametrage/fiscal"
@rendermode InteractiveServer
@attribute [Authorize(Policy = LiakontPermissions.Settings)]
@using Liakont.Host.BillingMentions
@using Liakont.Host.Fiscal
@using Liakont.Host.Components
@using Liakont.Host.Security
@using Stratum.Common.Abstractions.Security
@using Stratum.Common.UI.Models
@inject IFiscalConsoleService Service
@inject IBillingMentionsConsoleService MentionsService
@inject IPermissionService Permissions
@inject ILogger<Fiscal> Logger

<PageTitle>Paramètres fiscaux — Liakont</PageTitle>

<h1 class="visually-hidden">Paramètres fiscaux du tenant</h1>

@if (!_canManage)
{
    @* Paramétrage du tenant : réservé à liakont.settings. Sans la permission, aucune donnée n'est chargée et
       seul le message d'accès refusé est rendu (la garde serveur reste l'unique contrôle du chemin console). *@
    <LiakontAlert Severity="Severity.Warning" TestId="fiscal-denied">
        Accès refusé : le paramétrage fiscal du tenant requiert l'autorisation de paramétrage (liakont.settings).
        Rapprochez-vous de l'administrateur de votre organisation.
    </LiakontAlert>
}
else if (_loadFailed)
{
    <LiakontAlert TestId="fiscal-error">
        Impossible de charger le paramétrage fiscal du tenant pour le moment. Réessayez plus tard.
    </LiakontAlert>
}
else if (_model is null)
{
    <LiakontLoading TestId="fiscal-loading" />
}
else
{
    <FiscalView Model="_model"
                Busy="_busy"
                Message="@_message"
                IsError="_isError"
                OnSave="SaveAsync" />

    @* Mentions de facturation INTÉGRÉES à la page fiscale (BUG-26, ajustement PO) : section distincte avec
       son propre formulaire et son bouton Enregistrer. Chargée et enregistrée INDÉPENDAMMENT du paramétrage
       fiscal — un échec de chargement des mentions n'empêche pas l'édition fiscale ci-dessus. *@
    @if (_mentionsModel is not null)
    {
        <MentionsFacturationView Model="_mentionsModel"
                                 Busy="_mentionsBusy"
                                 Message="@_mentionsMessage"
                                 IsError="_mentionsIsError"
                                 OnSave="SaveMentionsAsync" />
    }
    else if (_mentionsLoadFailed)
    {
        <LiakontAlert TestId="mentions-error">
            Impossible de charger les mentions de facturation du tenant pour le moment. Réessayez plus tard.
        </LiakontAlert>
    }
}

@code {
    private FiscalViewModel? _model;
    private bool _loadFailed;

    /// <summary>Permission de paramétrage du tenant : conditionne TOUTE la page (accès + actions).</summary>
    private bool _canManage;

    private bool _busy;
    private string? _message;
    private bool _isError;

    // État de la section « Mentions de facturation », SÉPARÉ du paramétrage fiscal : chargement et
    // enregistrement indépendants (un échec côté mentions ne masque pas le formulaire fiscal).
    private BillingMentionsViewModel? _mentionsModel;
    private bool _mentionsLoadFailed;
    private bool _mentionsBusy;
    private string? _mentionsMessage;
    private bool _mentionsIsError;

    protected override async Task OnInitializedAsync()
    {
        // Contrôle côté serveur (circuit Blazor Server), non falsifiable côté client.
        _canManage = Permissions.HasPermission(LiakontPermissions.Settings);
        if (_canManage)
        {
            await LoadAsync();
            await LoadMentionsAsync();
        }
    }

    private async Task LoadAsync()
    {
        try
        {
            _model = await Service.GetAsync();
            _loadFailed = false;
        }
        catch (Exception ex)
        {
            // L'échec reste VISIBLE pour l'opérateur (bandeau) et tracé — jamais avalé en silence.
            _loadFailed = true;
            Logger.LogError(ex, "Failed to load the Liakont tenant fiscal settings page.");
        }
    }

    private async Task LoadMentionsAsync()
    {
        try
        {
            _mentionsModel = await MentionsService.GetAsync();
            _mentionsLoadFailed = false;
        }
        catch (Exception ex)
        {
            // Échec INDÉPENDANT du paramétrage fiscal : seule la section mentions affiche un bandeau,
            // le formulaire fiscal reste éditable. L'échec reste tracé — jamais avalé en silence.
            _mentionsLoadFailed = true;
            Logger.LogError(ex, "Failed to load the Liakont tenant billing mentions on the fiscal settings page.");
        }
    }

    private async Task ReloadAfterSaveAsync()
    {
        try
        {
            _model = await Service.GetAsync();
        }
        catch (Exception ex)
        {
            // Un échec de RECHARGEMENT après un enregistrement réussi ne doit pas masquer la réussite
            // (l'opérateur croirait l'envoi échoué — leçon WEB09). On garde le _model précédent.
            Logger.LogError(ex, "Failed to reload the Liakont tenant fiscal settings after a successful save.");
        }
    }

    private async Task SaveAsync()
    {
        if (_model is null)
        {
            return;
        }

        _busy = true;
        _message = null;
        _isError = false;

        try
        {
            await Service.SaveAsync(new FiscalSettingsInput
            {
                VatOnDebits = _model.Form.VatOnDebits,
                OperationCategory = _model.Form.OperationCategory,
                FeeImputationMethod = _model.Form.FeeImputationMethod,
                ReportingFrequency = _model.Form.ReportingFrequency,
            });
            await ReloadAfterSaveAsync();
            _message = "Paramètres fiscaux enregistrés.";
            _isError = false;
        }
        catch (ArgumentException)
        {
            // Valeur hors liste fermée rejetée par le handler (défense en profondeur) : message opérateur,
            // jamais de valeur devinée à la place de l'expert-comptable.
            _message = "Valeur de paramètre fiscal non reconnue. Choisissez une valeur proposée ou laissez « non renseigné ».";
            _isError = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save the Liakont tenant fiscal settings.");
            _message = "L'enregistrement des paramètres fiscaux a échoué. Réessayez plus tard.";
            _isError = true;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ReloadMentionsAfterSaveAsync()
    {
        try
        {
            _mentionsModel = await MentionsService.GetAsync();
        }
        catch (Exception ex)
        {
            // Un échec de RECHARGEMENT après un enregistrement réussi ne doit pas masquer la réussite
            // (l'opérateur croirait l'envoi échoué — leçon WEB09). On garde le _mentionsModel précédent.
            Logger.LogError(ex, "Failed to reload the Liakont tenant billing mentions after a successful save.");
        }
    }

    private async Task SaveMentionsAsync()
    {
        if (_mentionsModel is null)
        {
            return;
        }

        _mentionsBusy = true;
        _mentionsMessage = null;
        _mentionsIsError = false;

        try
        {
            await MentionsService.SaveAsync(new BillingMentionsInput
            {
                PaymentTerms = _mentionsModel.Form.PaymentTerms,
                LatePenaltyTerms = _mentionsModel.Form.LatePenaltyTerms,
                RecoveryFeeTerms = _mentionsModel.Form.RecoveryFeeTerms,
                DiscountTerms = _mentionsModel.Form.DiscountTerms,
            });
            await ReloadMentionsAfterSaveAsync();
            _mentionsMessage = "Mentions de facturation enregistrées.";
            _mentionsIsError = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save the Liakont tenant billing mentions settings.");
            _mentionsMessage = "L'enregistrement des mentions de facturation a échoué. Réessayez plus tard.";
            _mentionsIsError = true;
        }
        finally
        {
            _mentionsBusy = false;
        }
    }
}
