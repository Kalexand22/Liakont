@page "/supervision"
@rendermode InteractiveServer
@attribute [Authorize(Policy = LiakontPermissions.Supervision)]
@using Microsoft.Extensions.Logging
@using Stratum.Common.Abstractions.Grid
@using Stratum.Common.UI.Models
@using Liakont.Host.Security
@using Liakont.Host.Supervision
@using Liakont.Modules.Supervision.Contracts
@using Liakont.Modules.Supervision.Contracts.DTOs
@inject ISupervisionDashboardQueries Dashboard
@inject NavigationManager Nav
@inject ILogger<Supervision> Logger

<PageTitle>Supervision — Liakont</PageTitle>

<h1 class="visually-hidden">Supervision</h1>

<p class="supervision-intro" data-testid="supervision-intro">
    Vue d'ensemble de tous les tenants de l'instance : alertes actives, état des agents et files de
    documents. Les tenants à traiter (alertes critiques) apparaissent en tête.
</p>

@* Témoin de vie du dead-man's-switch (FIX210, F12 §5.1) : « aucune alerte » est sain SEULEMENT si le
   dispositif tourne — sinon c'est une panne silencieuse. Le bandeau rend cette distinction visible. *@
<SupervisionLivenessBanner />

@if (_loadFailed)
{
    <LiakontAlert TestId="supervision-error">
        Impossible de charger la supervision pour le moment. Réessayez plus tard.
    </LiakontAlert>
}
else
{
    @* Vue d'ensemble : gabarit DeclaredListPage (aucune grille « maison »). Données cross-tenant agrégées
       par le module Supervision (seul contexte cross-tenant — CLAUDE.md n°9). *@
    <DeclaredListPage @key="_loadEpoch"
                      TItem="TenantSupervisionRowDto"
                      Title="Supervision"
                      TestId="supervision"
                      LoadItems="LoadItemsAsync"
                      DetailUrl="@(t => $"/supervision/{t.TenantId}")"
                      ColumnRegistry="_registry"
                      ColumnTemplates="_columnTemplates"
                      GridKey="Liakont.Supervision"
                      RowActions="_rowActions"
                      AriaLabel="Vue d'ensemble de supervision par tenant"
                      SortKeySelector="SortKey"
                      DefaultSortColumn="Priority"
                      DefaultSortDirection="SortDirection.Descending"
                      SearchPlaceholder="Rechercher un tenant… (raccourci : /)"
                      AllowExport="true"
                      ExportFileName="supervision-tenants">
        <EmptyContent>
            <p data-testid="supervision-empty">Aucun tenant actif à superviser.</p>
        </EmptyContent>
    </DeclaredListPage>
}

@code {
    private readonly SupervisionTenantColumnRegistry _registry = new();

    private bool _loadFailed;
    private IReadOnlyList<TenantSupervisionRowDto> _rows = [];

    // @key de la liste : incrémenté après chaque chargement pour forcer DeclaredListPage à relire LoadItems
    // (il ne recharge pas tout seul — même mécanique que la page Documents).
    private int _loadEpoch;

    private readonly IReadOnlyList<GridRowAction<TenantSupervisionRowDto>> _rowActions;
    private readonly Dictionary<string, RenderFragment<TenantSupervisionRowDto>> _columnTemplates;

    public Supervision()
    {
        _rowActions =
        [
            new GridRowAction<TenantSupervisionRowDto>(
                Id: "view",
                Label: "Détails",
                Icon: "visibility",
                IsQuickAction: true,
                Callback: row =>
                {
                    Nav.NavigateTo($"/supervision/{row.TenantId}");
                    return Task.CompletedTask;
                }),
        ];

        _columnTemplates = new Dictionary<string, RenderFragment<TenantSupervisionRowDto>>
        {
            ["DisplayName"] = row => __builder =>
            {
                __builder.AddContent(0, row.DisplayName);
                if (row.ReadFailed)
                {
                    // Un tenant injoignable reste VISIBLE et signalé — jamais masqué (panne silencieuse).
                    __builder.OpenElement(1, "span");
                    __builder.AddAttribute(2, "class", "supervision-row__unavailable");
                    __builder.AddAttribute(3, "data-testid", "supervision-row-unavailable");
                    __builder.AddAttribute(4, "title", "Lecture indisponible : ce tenant n'a pas pu être interrogé.");
                    __builder.AddContent(5, " ⚠ données indisponibles");
                    __builder.CloseElement();
                }
            },
            ["ActiveAlertCount"] = row => __builder =>
            {
                __builder.AddContent(0, row.ActiveAlertCount == 0
                    ? "—"
                    : $"{SupervisionDisplay.SeverityLabel(row.WorstSeverity)} ({row.ActiveAlertCount})");
            },
            ["LastAgentSeenUtc"] = row => __builder =>
            {
                __builder.OpenComponent<LiakontDate>(0);
                __builder.AddAttribute(1, "Value", (DateTimeOffset?)row.LastAgentSeenUtc);
                __builder.AddAttribute(2, "NullText", "jamais vu");
                __builder.CloseComponent();
            },
        };
    }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private Task<IReadOnlyList<TenantSupervisionRowDto>> LoadItemsAsync() => Task.FromResult(_rows);

    private async Task LoadAsync()
    {
        try
        {
            _rows = await Dashboard.GetInstanceOverviewAsync();
            _loadFailed = false;
            _loadEpoch++;
        }
        catch (Exception ex)
        {
            // L'échec reste VISIBLE pour l'opérateur (bandeau) et tracé — jamais avalé en silence.
            _loadFailed = true;
            Logger.LogError(ex, "Failed to load the supervision instance overview.");
        }
    }

    // Tri par défaut = priorité opérateur (à traiter en tête), aligné sur l'ordre de l'agrégateur.
    // DeclaredListPage re-trie côté client : sans cette clé il retomberait sur un tri alphabétique
    // par nom, et un tenant critique en fin d'alphabet pourrait passer en page 2 — exactement la panne
    // silencieuse que la supervision doit éviter (F12 §5). Les colonnes cliquables gardent leur tri propre.
    private static object SortKey(TenantSupervisionRowDto row, string column) => column switch
    {
        "ActiveAlertCount" => row.ActiveAlertCount,
        "AgentCount" => row.AgentCount,
        "LastAgentSeenUtc" => row.LastAgentSeenUtc ?? DateTimeOffset.MinValue,
        "BlockedDocumentCount" => row.BlockedDocumentCount,
        "RejectedByPaDocumentCount" => row.RejectedByPaDocumentCount,
        "PendingDocumentCount" => row.PendingDocumentCount,
        "DisplayName" => row.DisplayName,
        _ => PriorityRank(row),
    };

    // Rang de priorité décroissant : lecture en échec > présence de critiques > nombre d'alertes actives.
    // L'égalité de rang conserve l'ordre d'entrée (tri stable) — l'agrégateur fournit déjà les lignes par nom.
    private static long PriorityRank(TenantSupervisionRowDto row) =>
        (row.ReadFailed ? 1L << 40 : 0L)
        + (row.CriticalAlertCount > 0 ? 1L << 20 : 0L)
        + row.ActiveAlertCount;
}
