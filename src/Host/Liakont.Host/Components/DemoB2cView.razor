@namespace Liakont.Host.Components
@using System.Globalization
@using Liakont.Host.Demo
@using Stratum.Common.UI.Components
@using Stratum.Common.UI.Models

@* DemoB2cView — rendu PUR de l'écran « Démo e-reporting B2C — Essentiel » (B2C04). Reçoit son modèle et l'état
 * d'action en paramètres (aucune injection métier, aucune logique) pour être testable en bUnit sans auth ni
 * base. Restitue le chemin Essentiel de bout en bout (extraction bordereau acheteur → pivot → mapping →
 * déclaration 10.3 via la PA → lien reporting↔pièces B2C03 → export contrôle fiscal), le déclenchement manuel
 * d'un traitement, et l'état transmis/accusé ou bloqué (régime non mappé, p. ex. régime 6) de chaque
 * déclaration. Gabarit Stratum (SectionCard, StratumButton, StatusBadge). 100 % français. *@

<div class="liakont-demo-b2c" data-testid="demo-b2c">

    <SectionCard Title="Démo e-reporting B2C — Essentiel" TestId="demo-b2c-intro">
        <p class="liakont-demo-b2c__intro">
            Cette page démontre le chemin <strong>Essentiel</strong> de l'e-reporting B2C de bout en bout, sur la
            Plateforme Agréée de démonstration (Fake) :
        </p>
        <ol class="liakont-demo-b2c__pipeline" data-testid="demo-b2c-pipeline">
            <li>extraction du bordereau acheteur (BA)</li>
            <li>pivot</li>
            <li>mapping TVA du tenant</li>
            <li>déclaration 10.3 transmise via la PA</li>
            <li>lien reporting↔pièces (B2C-03)</li>
            <li>export contrôle fiscal</li>
        </ol>
        <p class="liakont-demo-b2c__hint">
            Un régime non mappé (par exemple le régime&nbsp;6) <strong>bloque</strong> proprement la déclaration —
            elle n'est jamais transmise avec une valeur devinée.
        </p>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="liakont-demo-b2c__feedback"
                 role="@(IsError ? "alert" : "status")"
                 data-testid="demo-b2c-feedback">
                @Message
            </div>
        }

        @if (CanAct)
        {
            <StratumButton Text="@(Busy ? "Traitement en cours…" : "Lancer un traitement maintenant")"
                           Variant="ButtonVariant.Primary"
                           Size="ButtonSize.Small"
                           Disabled="@Busy"
                           OnClick="@(_ => OnTrigger.InvokeAsync())"
                           TestId="demo-b2c-trigger" />
        }
    </SectionCard>

    <SectionCard Title="Déclarations 10.3 du tenant" TestId="demo-b2c-declarations">
        @if (Model.Declarations.Count == 0)
        {
            <p data-testid="demo-b2c-empty">
                Aucune déclaration 10.3 pour ce tenant. Lancez l'extraction de démonstration (agent / jeu de
                données), puis un traitement, pour voir le chemin Essentiel.
            </p>
        }
        else
        {
            <table class="liakont-demo-b2c__table" data-testid="demo-b2c-table">
                <thead>
                    <tr>
                        <th scope="col">Déclaration</th>
                        <th scope="col">Émise le</th>
                        <th scope="col">Total TTC</th>
                        <th scope="col">État</th>
                        <th scope="col">Lien B2C-03</th>
                        <th scope="col">Export</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Declarations)
                    {
                        <tr data-testid="demo-b2c-row">
                            <td>@row.Number</td>
                            <td>@row.IssueDate.ToString("dd/MM/yyyy", CultureInfo.GetCultureInfo("fr-FR"))</td>
                            <td>@row.TotalGross.ToString("N2", CultureInfo.GetCultureInfo("fr-FR")) €</td>
                            <td><DocumentStateBadge State="@row.State" TestId="demo-b2c-state" /></td>
                            <td data-testid="demo-b2c-link">@(row.HasReportingLink ? "Gelé" : "—")</td>
                            <td>
                                <a href="@row.AuditExportUrl"
                                   download
                                   data-testid="demo-b2c-export">Exporter</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </SectionCard>

</div>

@code {
    /// <summary>Données assemblées de l'écran (jamais <c>null</c> : la page en fournit toujours un).</summary>
    [Parameter, EditorRequired]
    public DemoB2cViewModel Model { get; set; } = null!;

    /// <summary><c>true</c> pendant le déclenchement d'un traitement (bouton désactivé).</summary>
    [Parameter]
    public bool Busy { get; set; }

    /// <summary><c>true</c> si l'opérateur a la permission d'action (le bouton de déclenchement est alors offert).</summary>
    [Parameter]
    public bool CanAct { get; set; }

    /// <summary>Message de retour du déclenchement, ou <c>null</c>.</summary>
    [Parameter]
    public string? Message { get; set; }

    /// <summary><c>true</c> si <see cref="Message"/> est une erreur (rendu en alerte).</summary>
    [Parameter]
    public bool IsError { get; set; }

    /// <summary>Déclenché au lancement manuel d'un traitement.</summary>
    [Parameter]
    public EventCallback OnTrigger { get; set; }
}
