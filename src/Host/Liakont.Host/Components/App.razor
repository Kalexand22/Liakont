@using System.Globalization
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script>
        // Apply saved theme before first paint to prevent flash.
        // Must be inline in <head> so it runs before CSS is evaluated.
        (function() {
            var t = localStorage.getItem('stratum-theme');
            if (!t) t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            document.documentElement.setAttribute('data-theme', t);
        })();
        // Apply saved density mode before first paint (UIF06).
        // Compact is the Civic Blueprint default — standard is opt-in.
        // Setting the attribute here (before tokens.css is evaluated) guarantees
        // inputs/rows render at the final height on first paint, with no
        // flash-of-wrong-density when the circuit connects.
        (function() {
            var d = localStorage.getItem('stratum-density');
            if (d !== 'compact' && d !== 'standard') d = 'compact';
            document.documentElement.setAttribute('data-density', d);
        })();
        // Apply saved sidebar collapsed state before first paint to prevent FOUC.
        (function() {
            if (localStorage.getItem('stratum-sidebar-collapsed') === 'true') {
                document.documentElement.classList.add('sidebar-pre-collapsed');
            }
        })();
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          crossorigin="anonymous" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" />
    <link rel="stylesheet" href="/_content/Stratum.Common.UI/css/tokens.css" />
    <link rel="stylesheet" href="/_content/Stratum.Common.UI/css/components.css" />
    <link rel="stylesheet" href="/_content/Stratum.Common.UI/css/radzen-overrides.css" />
    <link rel="stylesheet" href="/Liakont.Host.styles.css" />
    <link rel="stylesheet" href="/css/app.css" />
    @* Branding d'instance (BRD01) : titre d'onglet, favicon, surcharge de thème — APRÈS les CSS du socle
       pour que la surcharge :root l'emporte sur tokens.css. *@
    <BrandingHead />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>
<body>
    <Routes />
    <script src="/_content/Stratum.Common.UI/js/stratum-ui.js"></script>
    <script src="/_content/Stratum.Common.UI/js/stratum-bugcapture.js"></script>
    @* RB6 — résolution du fuseau navigateur (servi par le RCL Stratum.Common.UI). *@
    <script src="/_content/Stratum.Common.UI/js/liakont-time.js"></script>
    <script src="/_framework/blazor.web.js"></script>
</body>
</html>
