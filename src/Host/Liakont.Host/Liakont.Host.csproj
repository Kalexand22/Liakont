<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <AssemblyName>Liakont.Host</AssemblyName>
    <RootNamespace>Liakont.Host</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Liakont.Host.Tests.Unit" />
    <InternalsVisibleTo Include="Liakont.Console.Api.Tests.Integration" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Asp.Versioning.Http" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.OpenIdConnect" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" />
    <PackageReference Include="Swashbuckle.AspNetCore.SwaggerUI" />
    <!-- Épinglage SÉCURITÉ (pas une nouvelle dépendance) : Microsoft.AspNetCore.OpenApi 10.0.0 tire
         transitivement Microsoft.OpenApi 2.0.0, frappé par l'avis GHSA-v5pm-xwqc-g5wc (NU1903, haute
         sévérité). Référence directe pour forcer la dernière 2.x patchée (API-compatible avec 10.0.0). -->
    <PackageReference Include="Microsoft.OpenApi" />
    <!-- Transport SMTP réel des notifications (ADR-0018, SUP03) — confiné au Host (composition root) ;
         aucun module métier ni module du socle ne référence MailKit/MimeKit. -->
    <PackageReference Include="MailKit" />
    <PackageReference Include="MimeKit" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Common\Infrastructure\Stratum.Common.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Common\UI\Stratum.Common.UI.csproj" />
    <ProjectReference Include="..\..\Modules\Identity\Infrastructure\Stratum.Modules.Identity.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\Identity\Web\Stratum.Modules.Identity.Web.csproj" />
    <ProjectReference Include="..\..\Modules\Job\Infrastructure\Stratum.Modules.Job.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\Job\Web\Stratum.Modules.Job.Web.csproj" />
    <ProjectReference Include="..\..\Modules\Notification\Infrastructure\Stratum.Modules.Notification.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\Notification\Web\Stratum.Modules.Notification.Web.csproj" />
    <ProjectReference Include="..\..\Modules\Audit\Infrastructure\Stratum.Modules.Audit.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\Audit\Web\Stratum.Modules.Audit.Web.csproj" />
    <ProjectReference Include="..\..\Modules\TenantSettings\Infrastructure\Liakont.Modules.TenantSettings.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\TenantSettings\Web\Liakont.Modules.TenantSettings.Web.csproj" />
    <ProjectReference Include="..\..\Modules\Ingestion\Infrastructure\Liakont.Modules.Ingestion.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\Ingestion\Contracts\Liakont.Modules.Ingestion.Contracts.csproj" />
    <ProjectReference Include="..\..\Modules\Ingestion\Web\Liakont.Modules.Ingestion.Web.csproj" />
    <ProjectReference Include="..\..\Modules\TvaMapping\Infrastructure\Liakont.Modules.TvaMapping.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\TvaMapping\Web\Liakont.Modules.TvaMapping.Web.csproj" />
    <!-- Mandats (F15 §2, ADR-0022) : MND01 monte la persistance (AddMandatsModule). La couche Web du
         module (endpoints console) est un squelette livré par MND01 mais non encore montée — elle sera
         référencée quand les écrans Mandats (items MND ultérieurs) ajouteront leurs routes. -->
    <ProjectReference Include="..\..\Modules\Mandats\Infrastructure\Liakont.Modules.Mandats.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\Documents\Infrastructure\Liakont.Modules.Documents.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\Documents\Web\Liakont.Modules.Documents.Web.csproj" />
    <ProjectReference Include="..\..\Modules\Payments\Infrastructure\Liakont.Modules.Payments.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\Archive\Infrastructure\Liakont.Modules.Archive.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\Archive\Web\Liakont.Modules.Archive.Web.csproj" />
    <ProjectReference Include="..\..\Modules\Staging\Infrastructure\Liakont.Modules.Staging.Infrastructure.csproj" />
    <!-- Trace de support du Factur-X transmis (FX06) : store dédié purgeable + job de purge. -->
    <ProjectReference Include="..\..\Modules\SupportTrace\Infrastructure\Liakont.Modules.SupportTrace.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\Reconciliation\Infrastructure\Liakont.Modules.Reconciliation.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\Reconciliation\Web\Liakont.Modules.Reconciliation.Web.csproj" />
    <ProjectReference Include="..\..\Modules\Supervision\Infrastructure\Liakont.Modules.Supervision.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\Supervision\Contracts\Liakont.Modules.Supervision.Contracts.csproj" />
    <!-- Méta-supervision de flotte (OPS04) : endpoint central, dashboard, jobs (Application pour les options,
         Infrastructure pour le store/jobs/collecteur, Contracts pour le transport et les lectures). -->
    <ProjectReference Include="..\..\Modules\FleetSupervision\Application\Liakont.Modules.FleetSupervision.Application.csproj" />
    <ProjectReference Include="..\..\Modules\FleetSupervision\Infrastructure\Liakont.Modules.FleetSupervision.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\FleetSupervision\Contracts\Liakont.Modules.FleetSupervision.Contracts.csproj" />
    <ProjectReference Include="..\..\Modules\Transmission\Infrastructure\Liakont.Modules.Transmission.Infrastructure.csproj" />
    <!-- Plug-in PA factice (PAA02) câblé au COMPOSITION ROOT uniquement (FIX01d). Seul le Host
         référence un plug-in PA concret (CLAUDE.md n°6/14) ; il n'est activé qu'en Development ou via
         PaClients:Fake:Enabled (voir PaClientBootstrap), jamais par défaut en production. -->
    <ProjectReference Include="..\..\PaClients\Liakont.PaClients.Fake\Liakont.PaClients.Fake.csproj" />
    <!-- Plug-in PA GÉNÉRIQUE (FXG, F16 §6) : PA réelle de niveau « Essentiel » (transmet un Factur-X
         pré-construit par email/dépôt de fichier). Câblé au COMPOSITION ROOT (CLAUDE.md n°6/14) ;
         résolu par PaType « Generique » uniquement. Les canaux de livraison Host (MimeKit) vivent au Host. -->
    <ProjectReference Include="..\..\PaClients\Liakont.PaClients.Generique\Liakont.PaClients.Generique.csproj" />
    <!-- Plug-in PA Super PDP (F14, OAuth2 client_credentials) : PA réelle de niveau « Pilotage ». Câblé au
         COMPOSITION ROOT (CLAUDE.md n°6/14) ; résolu par PaType « SuperPdp ». Le Host fournit le résolveur de
         compte (déchiffrement des secrets OAuth2 par tenant) ; le plug-in ne voit que Transmission.Contracts. -->
    <ProjectReference Include="..\..\PaClients\Liakont.PaClients.SuperPdp\Liakont.PaClients.SuperPdp.csproj" />
    <!-- Plug-in PA Chorus Pro (F18, OAuth2WithTechnicalAccount — dépôt d'un Factur-X scellé via PISTE) : PA B2G
         réelle. Câblé au COMPOSITION ROOT (CLAUDE.md n°6/14) ; résolu par PaType « ChorusPro ». Le Host fournit
         le résolveur de compte (déchiffrement des secrets PISTE + compte technique par tenant) ; le plug-in ne
         voit que Transmission.Contracts. -->
    <ProjectReference Include="..\..\PaClients\Liakont.PaClients.ChorusPro\Liakont.PaClients.ChorusPro.csproj" />
    <!-- Module FacturX (FX02-FX04) câblé au COMPOSITION ROOT par FX07 : le Host enregistre AddFacturXModule
         (port IFacturXBuilder, QuestPDF confinée à FacturX.Infrastructure) et expose le pont
         IFacturXArtifactBuilder vers Transmission.Contracts pour que le pipeline génère « derrière
         IFacturXBuilder » sans franchir la frontière Contracts-only (module-rules §3). -->
    <ProjectReference Include="..\..\Modules\FacturX\Infrastructure\Liakont.Modules.FacturX.Infrastructure.csproj" />
    <!-- Module Signature (SIG03, ADR-0027) : abstraction de signature à capacités. Le Host enregistre le
         registre de plug-ins (AddSignatureModule) et valide AU DÉMARRAGE les fournisseurs configurés —
         différence avec l'IdP : la signature est OPTIONNELLE (l'absence n'est jamais une erreur). Aucun
         plug-in concret référencé ici (Yousign = SIG07, câblé au composition root plus tard, CLAUDE.md n°6/14).
         Le plug-in SUR PLACE Wacom (SIG08) est enregistré PAR AddSignatureModule (frontière Contracts), pas
         référencé en dur ici. La couche Web monte le proxy OnSiteCapture (SIG08) ; SIG10 y ajoutera les pages. -->
    <ProjectReference Include="..\..\Modules\Signature\Infrastructure\Liakont.Modules.Signature.Infrastructure.csproj" />
    <!-- Plug-in de signature à distance Yousign (SIG07, ADR-0029) câblé au COMPOSITION ROOT uniquement
         (CLAUDE.md n°6/14) : le Host enregistre AddYousignSignatureProvider + fournit IYousignAccountResolver
         (déchiffrement via le coffre du tenant). Le registre du module Signature le découvre par son type. -->
    <ProjectReference Include="..\..\SignatureProviders\Liakont.SignatureProviders.Yousign\Liakont.SignatureProviders.Yousign.csproj" />
    <!-- Couche Web du module Signature : monte le proxy OnSiteCapture (SIG08) — POST capture sur place +
         enregistrement du signataire vérifié (MapSignatureEndpoints). -->
    <ProjectReference Include="..\..\Modules\Signature\Web\Liakont.Modules.Signature.Web.csproj" />
    <!-- Module DocumentApproval (SIG04, ADR-0028) : workflow de validation de document générique (cœur du lot
         signature). Le Host enregistre la persistance (migrations du schéma documentapproval + journal
         append-only, UoW, requêtes). Les ports par purpose (ISelfBilledGate réutilisé, …) et le câblage
         pipeline arrivent avec SIG06 ; le refactor de SelfBilledAcceptance (Mandats) avec SIG05. -->
    <ProjectReference Include="..\..\Modules\DocumentApproval\Infrastructure\Liakont.Modules.DocumentApproval.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\Validation\Infrastructure\Liakont.Modules.Validation.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\Pipeline\Infrastructure\Liakont.Modules.Pipeline.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\Pipeline\Web\Liakont.Modules.Pipeline.Web.csproj" />
    <ProjectReference Include="..\..\Contracts\Liakont.Agent.Contracts\Liakont.Agent.Contracts.csproj" />
    <!-- Formule de réconciliation BR-CO-13 (PivotReconciliation) partagée avec la validation : le contrôle
         de cohérence affiché (DocumentLineProjection, FIX205) est le MIROIR de LineTotalsRule via la même
         source-unique, désormais hors du contrat agent publiable (RDL12, ADR-0005). -->
    <ProjectReference Include="..\..\Platform\Liakont.Platform.Pivot\Liakont.Platform.Pivot.csproj" />
  </ItemGroup>

</Project>
