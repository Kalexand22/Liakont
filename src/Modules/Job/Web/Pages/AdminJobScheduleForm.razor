@page "/admin/jobs/new"
@page "/admin/jobs/{Id:guid}"
@page "/admin/jobs/{Id:guid}/edit"
@rendermode InteractiveServer
@attribute [Authorize]
@using MediatR
@using Stratum.Common.Abstractions.Collaboration
@using Stratum.Common.Abstractions.Security
@using Stratum.Modules.Job.Contracts.Commands
@using Stratum.Modules.Job.Contracts.Services
@inject ISender Sender
@inject IScheduleQueries ScheduleQueries
@inject IActorContextAccessor ActorContext
@inject ICronPreviewService CronPreview
@inject IJobTypeCatalog JobTypeCatalog
@inject ISystemScheduleHost SystemScheduleHost
@inject NavigationManager Nav
@inject IToastService ToastService

<PageTitle>@PageTitleText — Stratum ERP</PageTitle>

<PermissionGate Permission="@JobPermissions.View">
<DeclaredFormPage @ref="_formRef"
                  TEntity="ScheduleDto"
                  Id="@Id"
                  Title="@BuildTitle"
                  TestId="job-schedule-form"
                  ListUrl="/admin/jobs"
                  DetailUrl="@(id => $"/admin/jobs/{id}")"
                  CreateUrl="/admin/jobs/new"
                  EntityType="JobSchedule"
                  EnableViewMode="true"
                  InitialMode="@(_isEditRoute ? FormMode.Edit : FormMode.View)"
                  EditPermission="@JobPermissions.ManageSchedules"
                  LoadEntity="@(id => ScheduleQueries.GetByIdAsync(id))"
                  CreateEntity="CreateAsync"
                  UpdateEntity="UpdateAsync"
                  Validate="ValidateForm"
                  ClearErrors="ClearAllErrors"
                  MapEntity="MapFromDto"
                  ResetFields="ResetAllFields"
                  MapDomainError="MapError"
                  OnEntityChanged="HandleEntityChanged"
                  @bind-GlobalError="_globalError"
                  @bind-IsDirty="_isDirty">
    <StatusContent>
        @if (!IsCreateMode)
        {
            <StatusBadge Severity="@(_isActive ? Severity.Success : Severity.Neutral)"
                         Label="@(_isActive ? "Actif" : "Inactif")" />
        }
    </StatusContent>
    <HeaderActions Context="ctx">
        @if (ctx.Mode == FormMode.View && _isActive)
        {
            <PermissionGate Permission="@JobPermissions.ManageSchedules">
                <StratumButton Text="@(_toggling ? "Désactivation…" : "Désactiver")"
                               Variant="ButtonVariant.Warning" Outline Size="ButtonSize.Small"
                               OnClick="ToggleAsync"
                               Disabled="@_toggling"
                               TestId="job-schedule-form-toggle-btn" />
            </PermissionGate>
        }
        @if (ctx.Mode == FormMode.View && !_isActive)
        {
            <PermissionGate Permission="@JobPermissions.ManageSchedules">
                <StratumButton Text="@(_toggling ? "Activation…" : "Activer")"
                               Variant="ButtonVariant.Primary" Outline Size="ButtonSize.Small"
                               OnClick="ToggleAsync"
                               Disabled="@_toggling"
                               TestId="job-schedule-form-toggle-btn" />
            </PermissionGate>
        }
    </HeaderActions>
    <Content Context="ctx">
        <SectionCard Title="Planification" TestId="job-schedule-form-info">
            <div class="row g-3">
                <div class="col-md-6">
                    <FormField Label="Nom" Required Error="@_nameError">
                        <input type="text"
                               class="form-control"
                               value="@_name"
                               @oninput="HandleNameInput"
                               placeholder="Ex : Nettoyage quotidien, Relance hebdomadaire"
                               maxlength="200"
                               disabled="@(ctx.Mode == FormMode.View)"
                               data-testid="job-schedule-form-name" />
                    </FormField>
                </div>
                <div class="col-md-6">
                    <FormField Label="Type de job" Required Error="@_jobTypeError"
                               HelpText="Liste fixe des types réellement disponibles sur cette instance.">
                        @if (ctx.Mode == FormMode.View)
                        {
                            <p class="form-control-plaintext mb-0" data-testid="job-schedule-form-job-type-label">
                                @JobTypeLabel(_jobType)
                            </p>
                        }
                        else
                        {
                            <select class="form-select"
                                    value="@_jobType"
                                    @onchange="HandleJobTypeChange"
                                    data-testid="job-schedule-form-job-type">
                                <option value="" disabled selected="@(_jobType.Length == 0)">— Choisir un type —</option>
                                @foreach (var type in _jobTypes)
                                {
                                    <option value="@type.TechnicalKey" selected="@(type.TechnicalKey == _jobType)">@type.DisplayName</option>
                                }
                            </select>
                        }
                    </FormField>
                </div>
                @if (ctx.Mode != FormMode.View)
                {
                    <div class="col-md-6">
                        <FormField Label="Fréquence" HelpText="Choisissez un rythme courant, ou « Personnalisé » pour saisir le cron à la main.">
                            <div class="d-flex gap-2">
                                <select class="form-select"
                                        value="@_cronPreset"
                                        @onchange="HandleCronPresetChange"
                                        data-testid="job-schedule-form-cron-preset">
                                    <option value="custom">Personnalisé (avancé)</option>
                                    <option value="15min">Toutes les 15 minutes</option>
                                    <option value="hourly">Toutes les heures</option>
                                    <option value="daily">Tous les jours à…</option>
                                </select>
                                @if (_cronPreset == "daily")
                                {
                                    <input type="time"
                                           class="form-control"
                                           style="max-width: 8rem;"
                                           value="@_dailyTime"
                                           @onchange="HandleDailyTimeChange"
                                           data-testid="job-schedule-form-cron-daily-time" />
                                }
                            </div>
                        </FormField>
                    </div>
                }
                <div class="col-md-6">
                    <FormField Label="Expression cron" Required Error="@_cronError"
                               HelpText="Format : minute heure jour mois jour-semaine. Interprété en UTC.">
                        <input type="text"
                               class="form-control"
                               value="@_cronExpression"
                               @oninput="HandleCronInput"
                               placeholder="0 2 * * *"
                               maxlength="100"
                               disabled="@(ctx.Mode == FormMode.View)"
                               data-testid="job-schedule-form-cron" />
                    </FormField>
                </div>
                <div class="col-md-6">
                    <FormField Label="Actif">
                        <Switch Value="@_isActive"
                                ValueChanged="HandleActiveChange"
                                Disabled="@(ctx.Mode == FormMode.View)"
                                TestId="job-schedule-form-active" />
                    </FormField>
                </div>
                @* Payload typé (FIX211) : champs générés depuis les propriétés du type sélectionné. Masqué pour
                   les types sans paramètre (déclencheurs vides : cas majoritaire). Plus de JSON brut à saisir. *@
                @foreach (var p in _selectedParams)
                {
                    <div class="col-md-6" data-testid="@($"job-schedule-form-param-{p.Name}")">
                        <FormField Label="@p.Label" Required="@p.Required" Error="@GetParamError(p.Name)">
                            @if (p.Kind == JobParameterKind.Boolean)
                            {
                                <Switch Value="@GetParamBool(p.Name)"
                                        ValueChanged="@(v => HandleParamBoolChange(p.Name, v))"
                                        Disabled="@(ctx.Mode == FormMode.View)"
                                        TestId="@($"job-schedule-form-param-input-{p.Name}")" />
                            }
                            else if (p.Kind == JobParameterKind.Enum)
                            {
                                <select class="form-select"
                                        value="@GetParamValue(p.Name)"
                                        @onchange="@(e => HandleParamChange(p.Name, e))"
                                        disabled="@(ctx.Mode == FormMode.View)"
                                        data-testid="@($"job-schedule-form-param-input-{p.Name}")">
                                    <option value="">—</option>
                                    @foreach (var opt in p.EnumOptions)
                                    {
                                        <option value="@opt" selected="@(opt == GetParamValue(p.Name))">@opt</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="@ParamInputType(p.Kind)"
                                       class="form-control"
                                       value="@GetParamValue(p.Name)"
                                       @oninput="@(e => HandleParamChange(p.Name, e))"
                                       disabled="@(ctx.Mode == FormMode.View)"
                                       data-testid="@($"job-schedule-form-param-input-{p.Name}")" />
                            }
                        </FormField>
                    </div>
                }
            </div>
        </SectionCard>

        @if (_cronPreviewLines.Count > 0 || _cronPreviewError is not null)
        {
            <SectionCard Title="Aperçu des 3 prochaines exécutions (UTC)" TestId="job-schedule-form-cron-preview">
                @if (_cronPreviewError is not null)
                {
                    <p class="text-danger small" data-testid="job-schedule-form-cron-preview-error">@_cronPreviewError</p>
                }
                else
                {
                    <ol class="mb-0" data-testid="job-schedule-form-cron-preview-list">
                        @foreach (var line in _cronPreviewLines)
                        {
                            <li class="small text-muted">@line</li>
                        }
                    </ol>
                }
            </SectionCard>
        }
    </Content>
    <AuditSection>
        @if (!IsCreateMode)
        {
            <SectionCard Title="Audit" Collapsible DefaultCollapsed TestId="job-schedule-form-audit">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Identifiant</dt>
                    <dd class="col-sm-9"><code class="text-muted small">@Id</code></dd>
                    <dt class="col-sm-3">Créé le</dt>
                    <dd class="col-sm-9"><LiakontDate Value="@_createdAt" /></dd>
                    @if (_updatedAt != default)
                    {
                        <dt class="col-sm-3">Modifié le</dt>
                        <dd class="col-sm-9"><LiakontDate Value="@_updatedAt" /></dd>
                    }
                </dl>
            </SectionCard>
        }
    </AuditSection>
</DeclaredFormPage>
</PermissionGate>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private DeclaredFormPage<ScheduleDto>? _formRef;

    private bool IsCreateMode => Id is null;
    private bool _isEditRoute;

    private string _name = string.Empty;
    private string _cronExpression = string.Empty;
    private string _jobType = string.Empty;
    private string _payloadTemplate = "{}";
    private bool _isActive = true;
    private DateTimeOffset _createdAt;
    private DateTimeOffset _updatedAt;
    private bool _isDirty;
    private bool _toggling;

    private string _origName = string.Empty;
    private string _origCronExpression = string.Empty;
    private string _origJobType = string.Empty;
    private string _origPayloadTemplate = "{}";
    private bool _origIsActive = true;

    private string? _nameError;
    private string? _cronError;
    private string? _jobTypeError;
    private string? _globalError;

    private List<string> _cronPreviewLines = [];
    private string? _cronPreviewError;

    // FIX211 — liste fixe des types de jobs (libellés FR) + payload typé + helper cron.
    private IReadOnlyList<JobTypeDescriptor> _jobTypes = [];
    private IReadOnlyList<JobParameterDescriptor> _selectedParams = [];
    private readonly Dictionary<string, string> _paramValues = new(StringComparer.Ordinal);
    private readonly Dictionary<string, string?> _paramErrors = new(StringComparer.Ordinal);
    private string _cronPreset = "custom";
    private string _dailyTime = "02:00";

    private static readonly System.Globalization.CultureInfo FrCulture = new("fr-FR");

    private string PageTitleText =>
        IsCreateMode ? "Nouvelle planification" :
        _isEditRoute ? "Modifier planification" :
        _name.Length > 0 ? _name : "Planification";

    private string BuildTitle(bool createMode) =>
        createMode ? "Nouvelle planification" : _name.Length > 0 ? _name : "Planification";

    protected override void OnInitialized()
    {
        _jobTypes = JobTypeCatalog.GetAll();
    }

    protected override void OnParametersSet()
    {
        _isEditRoute = new Uri(Nav.Uri).AbsolutePath.EndsWith("/edit", StringComparison.OrdinalIgnoreCase);
    }

    private string JobTypeLabel(string technicalKey)
    {
        if (string.IsNullOrEmpty(technicalKey))
        {
            return "—";
        }

        var descriptor = JobTypeCatalog.Find(technicalKey);
        if (descriptor is not null)
        {
            return descriptor.DisplayName;
        }

        // Repli pour un type historique non enregistré : nom court, JAMAIS le FullName complet.
        var lastDot = technicalKey.LastIndexOf('.');
        return lastDot >= 0 && lastDot < technicalKey.Length - 1
            ? technicalKey[(lastDot + 1)..]
            : technicalKey;
    }

    private void MapFromDto(ScheduleDto dto)
    {
        _name = dto.Name;
        _cronExpression = dto.CronExpression;
        _jobType = dto.JobType;
        _payloadTemplate = dto.PayloadTemplate;
        _isActive = dto.IsActive;
        _createdAt = dto.CreatedAt;
        _updatedAt = dto.UpdatedAt;
        _origName = dto.Name;
        _origCronExpression = dto.CronExpression;
        _origJobType = dto.JobType;
        _origPayloadTemplate = dto.PayloadTemplate;
        _origIsActive = dto.IsActive;
        LoadSelectedParams();
        ParsePayloadIntoParams(_payloadTemplate);
        DetectCronPreset();
        UpdateCronPreview();
    }

    private void ResetAllFields()
    {
        _name = string.Empty;
        _cronExpression = string.Empty;
        _jobType = string.Empty;
        _payloadTemplate = "{}";
        _isActive = true;
        _createdAt = default;
        _updatedAt = default;
        _origName = string.Empty;
        _origCronExpression = string.Empty;
        _origJobType = string.Empty;
        _origPayloadTemplate = "{}";
        _origIsActive = true;
        _cronPreviewLines = [];
        _cronPreviewError = null;
        _selectedParams = [];
        _paramValues.Clear();
        _paramErrors.Clear();
        _cronPreset = "custom";
        _dailyTime = "02:00";
    }

    private bool ValidateForm()
    {
        var valid = true;
        if (string.IsNullOrWhiteSpace(_name))
        {
            _nameError = "Le nom est obligatoire.";
            valid = false;
        }

        var cronResult = CronPreview.Validate(_cronExpression);
        if (!cronResult.IsValid)
        {
            _cronError = cronResult.ErrorMessage;
            valid = false;
        }

        if (string.IsNullOrWhiteSpace(_jobType))
        {
            _jobTypeError = "Le type de job est obligatoire.";
            valid = false;
        }
        else if (JobTypeCatalog.Find(_jobType) is null)
        {
            // Liste fixe : un type qui n'est pas enregistré sur l'instance est refusé (E7).
            _jobTypeError = "Type de job inexistant sur cette instance.";
            valid = false;
        }

        foreach (var p in _selectedParams)
        {
            var raw = GetParamValue(p.Name);
            if (p.Required && p.Kind != JobParameterKind.Boolean && string.IsNullOrWhiteSpace(raw))
            {
                _paramErrors[p.Name] = "Ce paramètre est obligatoire.";
                valid = false;
                continue;
            }

            if (!string.IsNullOrWhiteSpace(raw)
                && p.Kind == JobParameterKind.Number
                && !decimal.TryParse(raw, System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out _))
            {
                _paramErrors[p.Name] = "Nombre attendu.";
                valid = false;
            }
        }

        return valid;
    }

    private void ClearAllErrors()
    {
        _nameError = null;
        _cronError = null;
        _jobTypeError = null;
        _paramErrors.Clear();
    }

    private async Task<Guid> CreateAsync()
    {
        // BUG-4b — un opérateur tenant garde SA société courante (jamais d'écriture hors de son périmètre,
        // quel que soit le type choisi). Un opérateur PLATEFORME (sans société courante) qui planifie un job
        // SYSTÈME (fan-out tous tenants) le porte sur la société porteuse système : UNE planification couvre
        // tous les tenants (le fan-out est assuré par les handlers, indépendamment de cette société). Sans
        // société ni porteuse (opérateur plateforme + job tenant-scopé) → échec VISIBLE (BUG-4 volet A).
        var companyId = ActorContext.Current.CompanyId
            ?? SystemScheduleHost.ResolveHostCompanyId(_jobType)
            ?? throw new InvalidOperationException("Aucune société sélectionnée.");

        return await Sender.Send(new CreateScheduleCommand
        {
            Name = _name.Trim(),
            CronExpression = _cronExpression.Trim(),
            JobType = _jobType.Trim(),
            PayloadTemplate = string.IsNullOrWhiteSpace(_payloadTemplate) ? "{}" : _payloadTemplate.Trim(),
            CompanyId = companyId,
        });
    }

    private async Task UpdateAsync()
    {
        await Sender.Send(new UpdateScheduleCommand
        {
            ScheduleId = Id!.Value,
            Name = _name.Trim(),
            CronExpression = _cronExpression.Trim(),
            JobType = _jobType.Trim(),
            PayloadTemplate = string.IsNullOrWhiteSpace(_payloadTemplate) ? "{}" : _payloadTemplate.Trim(),
        });
    }

    // Retourne null si l'erreur est mappée à un champ ; sinon le message à afficher en bannière globale
    // (le socle possède l'affichage global — BUG-4 volet A).
    private string? MapError(string message)
    {
        var lower = message.ToLowerInvariant();
        if (lower.Contains("name") || lower.Contains("nom") || lower.Contains("inv-job-005"))
            _nameError = message;
        else if (lower.Contains("cron") || lower.Contains("inv-job-004"))
            _cronError = message;
        else if (lower.Contains("job type") || lower.Contains("type"))
            _jobTypeError = message;
        else
            // Payload structuré (champs typés) ou échec hors domaine (« Aucune société sélectionnée. ») :
            // aucun champ dédié → le socle le surface en erreur globale VISIBLE.
            return message;

        return null;
    }

    private void HandleNameInput(ChangeEventArgs e)
    {
        _name = e.Value?.ToString() ?? string.Empty;
        _isDirty = true;
        _nameError = null;
    }

    private void HandleCronInput(ChangeEventArgs e)
    {
        _cronExpression = e.Value?.ToString() ?? string.Empty;
        _isDirty = true;
        _cronError = null;
        UpdateCronPreview();
    }

    private void HandleJobTypeChange(ChangeEventArgs e)
    {
        _jobType = e.Value?.ToString() ?? string.Empty;
        _isDirty = true;
        _jobTypeError = null;
        LoadSelectedParams();
        _paramErrors.Clear();
        foreach (var p in _selectedParams)
        {
            _paramValues[p.Name] = p.DefaultValue ?? (p.Kind == JobParameterKind.Boolean ? "false" : string.Empty);
        }

        RebuildPayload();
    }

    private void LoadSelectedParams()
    {
        var descriptor = string.IsNullOrEmpty(_jobType) ? null : JobTypeCatalog.Find(_jobType);
        _selectedParams = descriptor?.Parameters ?? [];
    }

    private string GetParamValue(string name) => _paramValues.TryGetValue(name, out var v) ? v : string.Empty;

    private bool GetParamBool(string name) => bool.TryParse(GetParamValue(name), out var b) && b;

    private string? GetParamError(string name) => _paramErrors.TryGetValue(name, out var e) ? e : null;

    private static string ParamInputType(JobParameterKind kind) =>
        kind == JobParameterKind.Number ? "number" : "text";

    private void HandleParamChange(string name, ChangeEventArgs e)
    {
        _paramValues[name] = e.Value?.ToString() ?? string.Empty;
        _paramErrors[name] = null;
        _isDirty = true;
        RebuildPayload();
    }

    private void HandleParamBoolChange(string name, bool value)
    {
        _paramValues[name] = value ? "true" : "false";
        _isDirty = true;
        RebuildPayload();
    }

    // Sérialise les champs typés en JSON (clés camelCase, valeurs typées). Le JobHandlerResolver désérialise en
    // camelCase + insensible à la casse — les valeurs par défaut des records s'appliquent aux clés omises.
    private void RebuildPayload()
    {
        if (_selectedParams.Count == 0)
        {
            _payloadTemplate = "{}";
            return;
        }

        var dict = new Dictionary<string, object?>(StringComparer.Ordinal);
        foreach (var p in _selectedParams)
        {
            var key = System.Text.Json.JsonNamingPolicy.CamelCase.ConvertName(p.Name);
            var raw = GetParamValue(p.Name);
            switch (p.Kind)
            {
                case JobParameterKind.Boolean:
                    dict[key] = GetParamBool(p.Name);
                    break;
                case JobParameterKind.Number:
                    if (long.TryParse(raw, System.Globalization.NumberStyles.Integer, System.Globalization.CultureInfo.InvariantCulture, out var l))
                    {
                        dict[key] = l;
                    }
                    else if (decimal.TryParse(raw, System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out var dec))
                    {
                        dict[key] = dec;
                    }

                    break;
                default:
                    if (!string.IsNullOrEmpty(raw))
                    {
                        dict[key] = raw;
                    }

                    break;
            }
        }

        _payloadTemplate = System.Text.Json.JsonSerializer.Serialize(dict);
    }

    private void ParsePayloadIntoParams(string? json)
    {
        foreach (var p in _selectedParams)
        {
            _paramValues[p.Name] = p.DefaultValue ?? (p.Kind == JobParameterKind.Boolean ? "false" : string.Empty);
        }

        if (string.IsNullOrWhiteSpace(json))
        {
            return;
        }

        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.ValueKind != System.Text.Json.JsonValueKind.Object)
            {
                return;
            }

            foreach (var p in _selectedParams)
            {
                if (!TryGetPropertyCaseInsensitive(doc.RootElement, p.Name, out var el))
                {
                    continue;
                }

                _paramValues[p.Name] = el.ValueKind switch
                {
                    System.Text.Json.JsonValueKind.True => "true",
                    System.Text.Json.JsonValueKind.False => "false",
                    System.Text.Json.JsonValueKind.String => el.GetString() ?? string.Empty,
                    System.Text.Json.JsonValueKind.Number => el.GetRawText(),
                    _ => el.GetRawText(),
                };
            }
        }
        catch (System.Text.Json.JsonException)
        {
            // Payload historique illisible : on conserve les valeurs par défaut (pas d'exception à l'écran).
        }
    }

    private static bool TryGetPropertyCaseInsensitive(System.Text.Json.JsonElement obj, string name, out System.Text.Json.JsonElement value)
    {
        foreach (var prop in obj.EnumerateObject())
        {
            if (string.Equals(prop.Name, name, StringComparison.OrdinalIgnoreCase))
            {
                value = prop.Value;
                return true;
            }
        }

        value = default;
        return false;
    }

    private void HandleCronPresetChange(ChangeEventArgs e)
    {
        _cronPreset = e.Value?.ToString() ?? "custom";
        ApplyCronPreset();
    }

    private void HandleDailyTimeChange(ChangeEventArgs e)
    {
        _dailyTime = e.Value?.ToString() ?? "02:00";
        if (_cronPreset == "daily")
        {
            ApplyCronPreset();
        }
    }

    private void ApplyCronPreset()
    {
        switch (_cronPreset)
        {
            case "15min":
                _cronExpression = "*/15 * * * *";
                break;
            case "hourly":
                _cronExpression = "0 * * * *";
                break;
            case "daily":
                var parts = (_dailyTime ?? "02:00").Split(':');
                var hour = parts.Length > 0 && int.TryParse(parts[0], out var h) ? h : 0;
                var minute = parts.Length > 1 && int.TryParse(parts[1], out var m) ? m : 0;
                _cronExpression = $"{minute} {hour} * * *";
                break;
            case "custom":
            default:
                // Mode avancé : l'opérateur saisit le cron à la main dans le champ « Expression cron ».
                break;
        }

        _isDirty = true;
        _cronError = null;
        UpdateCronPreview();
    }

    private void DetectCronPreset()
    {
        var cron = (_cronExpression ?? string.Empty).Trim();
        if (cron == "*/15 * * * *")
        {
            _cronPreset = "15min";
            return;
        }

        if (cron == "0 * * * *")
        {
            _cronPreset = "hourly";
            return;
        }

        var parts = cron.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 5 && parts[2] == "*" && parts[3] == "*" && parts[4] == "*"
            && int.TryParse(parts[0], out var m) && m is >= 0 and < 60
            && int.TryParse(parts[1], out var h) && h is >= 0 and < 24)
        {
            _cronPreset = "daily";
            _dailyTime = $"{h:D2}:{m:D2}";
            return;
        }

        _cronPreset = "custom";
    }

    private void HandleActiveChange(bool value)
    {
        _isActive = value;
        _isDirty = true;
    }

    private void UpdateCronPreview()
    {
        _cronPreviewLines = [];
        _cronPreviewError = null;

        if (string.IsNullOrWhiteSpace(_cronExpression))
            return;

        var result = CronPreview.Validate(_cronExpression);
        if (!result.IsValid)
        {
            _cronPreviewError = "Expression cron invalide — aperçu indisponible.";
            return;
        }

        var occurrences = CronPreview.GetNextOccurrences(_cronExpression, 3);
        // PRÉVISION serveur : le cron est INTERPRÉTÉ EN UTC (cf. titre « (UTC) ») → aperçu en UTC EXPLICITE,
        // cohérent avec NextRunAt de la liste. Les ÉVÉNEMENTS de la fiche (Créé/Modifié le) sont, eux, au fuseau
        // du navigateur (<LiakontDate>). Une prévision affichée en heure locale induirait en erreur (le cron fire en UTC).
        _cronPreviewLines = occurrences
            .Select(o => o.UtcDateTime.ToString("dddd dd MMMM yyyy 'à' HH:mm 'UTC'", FrCulture))
            .ToList();
    }

    private async Task ToggleAsync()
    {
        if (Id is null || _toggling) return;

        _toggling = true;
        try
        {
            await Sender.Send(new ToggleScheduleCommand { ScheduleId = Id.Value });
            var label = _isActive ? "désactivée" : "activée";
            ToastService.Show($"Planification {label}.", Severity.Success);
            if (_formRef is not null)
            {
                await _formRef.ReloadAsync();
            }
        }
        catch (Exception ex)
        {
            ToastService.Show($"Erreur : {ex.Message}", Severity.Error);
        }
        finally
        {
            _toggling = false;
        }
    }

    private async Task HandleEntityChanged(EntityChangedEvent evt)
    {
        if (!_isDirty && _formRef is not null)
        {
            await _formRef.ReloadAsync();
            ToastService.Show($"Mise à jour par {evt.ChangedBy} appliquée.", Severity.Info);
            return;
        }

        ScheduleDto? serverDto;
        try
        {
            serverDto = await ScheduleQueries.GetByIdAsync(Id!.Value);
        }
        catch
        {
            ToastService.Show("Impossible de recharger les données.", Severity.Error);
            return;
        }

        if (serverDto is null) return;

        var conflicts = new List<string>();

        if (_name == _origName)
            _name = serverDto.Name;
        else if (serverDto.Name != _origName)
            conflicts.Add("Nom");

        if (_cronExpression == _origCronExpression)
        {
            _cronExpression = serverDto.CronExpression;
            UpdateCronPreview();
        }
        else if (serverDto.CronExpression != _origCronExpression)
            conflicts.Add("Expression cron");

        if (_jobType == _origJobType)
            _jobType = serverDto.JobType;
        else if (serverDto.JobType != _origJobType)
            conflicts.Add("Type de job");

        if (_payloadTemplate == _origPayloadTemplate)
            _payloadTemplate = serverDto.PayloadTemplate;
        else if (serverDto.PayloadTemplate != _origPayloadTemplate)
            conflicts.Add("Template payload");

        if (_isActive == _origIsActive)
            _isActive = serverDto.IsActive;
        else if (serverDto.IsActive != _origIsActive)
            conflicts.Add("Actif");

        _createdAt = serverDto.CreatedAt;
        _updatedAt = serverDto.UpdatedAt;
        _origName = serverDto.Name;
        _origCronExpression = serverDto.CronExpression;
        _origJobType = serverDto.JobType;
        _origPayloadTemplate = serverDto.PayloadTemplate;
        _origIsActive = serverDto.IsActive;

        // Re-synchronise les champs dérivés (params typés du type courant, preset cron) après le merge.
        LoadSelectedParams();
        ParsePayloadIntoParams(_payloadTemplate);
        DetectCronPreset();
        UpdateCronPreview();

        if (conflicts.Count > 0)
        {
            ToastService.Show($"Conflit détecté sur : {string.Join(", ", conflicts)}. Vos modifications sont conservées.", Severity.Warning);
        }
        else
        {
            _isDirty = _name != _origName || _cronExpression != _origCronExpression ||
                       _jobType != _origJobType || _payloadTemplate != _origPayloadTemplate ||
                       _isActive != _origIsActive;
            ToastService.Show($"Mise à jour par {evt.ChangedBy} appliquée.", Severity.Info);
        }
    }
}
