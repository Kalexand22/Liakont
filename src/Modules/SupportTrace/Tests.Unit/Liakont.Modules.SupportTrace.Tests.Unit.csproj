<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>
  <ItemGroup>
    <!-- EphemeralDataProtectionProvider (chiffrement en mémoire pour les tests) + ServiceCollection
         (test de l'enregistrement DI) vivent dans le framework partagé Microsoft.AspNetCore.App. -->
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" PrivateAssets="all" />
    <PackageReference Include="FluentAssertions" />
    <!-- Garde de frontière du module (aucune dépendance Documents/Archive). -->
    <PackageReference Include="NetArchTest.Rules" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../Contracts/Liakont.Modules.SupportTrace.Contracts.csproj" />
    <ProjectReference Include="../Infrastructure/Liakont.Modules.SupportTrace.Infrastructure.csproj" />
  </ItemGroup>
</Project>
