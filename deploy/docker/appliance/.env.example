# ─────────────────────────────────────────────────────────────────────────────
# Appliance Liakont — modèle de configuration d'instance (OPS01a, F12 §6.2)
#
#   cp .env.example .env   puis renseignez CHAQUE valeur ci-dessous.
#
# AUCUN secret n'a de valeur par défaut : générez-les vous-même (commandes indiquées).
# Le fichier .env (rempli) NE DOIT PAS être versionné (il est ignoré par .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# === Hôtes publics ==========================================================
# DNS pointant vers cette machine (A/AAAA). Caddy obtient un certificat TLS par hôte.
PUBLIC_HOSTNAME=liakont.example.com
KEYCLOAK_HOSTNAME=id.example.com

# URLs publiques complètes (https://<hôte>). Doivent correspondre aux hôtes ci-dessus.
PUBLIC_BASE_URL=https://liakont.example.com
KEYCLOAK_PUBLIC_URL=https://id.example.com

# Adresse e-mail pour l'enregistrement Let's Encrypt (ACME).
ACME_EMAIL=ops@example.com

# === Secrets — À GÉNÉRER (laisser vide = le démarrage échoue volontairement) =
# Générer une valeur forte, par ex. :  openssl rand -base64 32   (ou : pwgen -s 32 1)
# Utiliser de préférence des caractères alphanumériques (évite les soucis d'échappement).

# Mot de passe PostgreSQL de la base applicative (système + tenants).
POSTGRES_PASSWORD=

# Mot de passe PostgreSQL de la base dédiée à Keycloak.
KC_DB_PASSWORD=

# Compte d'amorçage de l'admin Keycloak (console d'administration de l'IdP).
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=

# Secret du client OIDC confidentiel « liakont ». La MÊME valeur est injectée dans Keycloak
# (import du realm) et lue par le Host (Keycloak__ClientSecret) — ne la divergez jamais.
KEYCLOAK_LIAKONT_CLIENT_SECRET=

# === E-mail sortant (OPTIONNEL) =============================================
# Laisser SMTP_ENABLED=false tant qu'aucun serveur SMTP n'est configuré.
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=

# Adresse de l'opérateur d'instance pour les alertes de supervision (OPTIONNEL).
OPERATOR_EMAIL=

# === Brokering SSO Google / Microsoft (OPTIONNEL — RLM05, ADR-0021 §4) =======
# Le login SSO est DORMANT par défaut (providers enabled:false dans realm-liakont.json) : la
# mécanique et la garde anti-prise-de-contrôle (trustEmail=false + « Verify existing account by
# email », JAMAIS d'auto-création) sont livrées et prouvées statiquement, mais la RECETTE RÉELLE
# exige des credentials opérateur (console développeur Google / Entra) et se fait au déploiement.
#
# Pour activer un provider :
#   1. Renseignez les identifiants OAuth ci-dessous (ne JAMAIS les versionner — n°10/18).
#   2. Passez le provider correspondant à "enabled": true dans keycloak/realm-liakont.json.
#   3. Recette : un utilisateur DÉJÀ provisionné se connecte via SSO (liaison par email vérifié).
# Le SSO ne crée jamais de compte : il LIE une identité externe à un compte Liakont existant.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
